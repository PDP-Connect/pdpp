{
  "lanes": {
    "stale_seconds": 14400
  },
  "mutexes": [
    {
      "name": "live-stack",
      "file": "tmp/workstreams/ri-owner-current-state.md",
      "open_pattern": "^- Status: OPEN"
    }
  ],
  "blockers": {
    "globs": [
      ".git/workstreams/blockers/*"
    ]
  },
  "reports": {
    "globs": [
      "tmp/workstreams/*.md"
    ],
    "limit": 30
  },
  "commands": [
    {
      "name": "OpenSpec status",
      "command": "node scripts/openspec-status.mjs",
      "severity": "warn"
    }
  ]
}
