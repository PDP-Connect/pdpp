{
  "name": "pdpp",
  "version": "1.0.0",
  "private": true,
  "description": "PDPP protocol specs, reference implementation, docs site, and design workbench.",
  "type": "module",
  "scripts": {
    "//dev": "Default contributor workflow (design.md §5): boots reference-implementation (AS :7662 / RS :7663) + apps/console. See scripts/dev.mjs.",
    "dev": "node scripts/dev.mjs",
    "dev:stop": "sh -c 'WEB_PORT=${PDPP_WEB_PORT:-3000}; fuser -k \"$WEB_PORT/tcp\" 3002/tcp 7662/tcp 7663/tcp 2>/dev/null; npx --yes kill-port 7662 7663 \"$WEB_PORT\" 3002 2>/dev/null; true'",
    "//build": "Default build/preview/start target is the operator console (apps/console), the live-runtime successor surface from the public-site/operator-console split. Public docs site uses site:build/site:start.",
    "build": "pnpm console:build",
    "preview": "pnpm console:start",
    "start": "pnpm console:start",
    "docker:dev": "docker compose --env-file .env.docker -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:reference:up": "bash scripts/reference-stack.sh up",
    "docker:reference:quick": "bash scripts/reference-stack.sh up --no-build",
    "docker:reference:build-all": "bash scripts/reference-stack.sh up --build-all",
    "docker:reference:verify": "bash scripts/reference-stack.sh verify",
    "docker:reference:ps": "bash scripts/reference-stack.sh ps",
    "docker:neko": "bash scripts/reference-stack.sh up",
    "docker:neko:turn": "docker compose --profile turn --env-file .env.docker -f docker-compose.yml -f docker-compose.neko.yml up --build",
    "docker:smoke": "bash scripts/docker-smoke.sh",
    "docker:neko:dynamic-allocator-smoke": "bash scripts/docker-neko-dynamic-allocator-smoke.sh",
    "docker:stream-smoke": "node scripts/manual-action-stream-smoke.mjs",
    "//docker-deploy": "Docker self-host deploy gate (deploy/docker/README.md). first-boot:test pins the standalone Core image's first-boot owner-credential bootstrap (generate, persist on the data volume, banner once, env always wins).",
    "docker:first-boot:test": "node --test scripts/docker-core-first-boot.test.mjs",
    "//railway": "Railway Core deploy gate (deploy/railway/README.md). template:test checks pushbutton template artifacts; ghcr-public probes the live anonymous-pull gate that blocks publishing the button (ghcr-public:test is its offline logic); env-check is the offline preflight; mcp-query-smoke seeds records + proves the scoped MCP query; sqlite-restart-smoke proves SQLite-on-volume durability across a container replacement.",
    "railway:template:test": "node --test scripts/check-railway-template-artifacts.test.mjs",
    "railway:ghcr-public": "node scripts/check-railway-ghcr-public.mjs",
    "railway:ghcr-public:test": "node --test scripts/check-railway-ghcr-public.test.mjs",
    "railway:env-check": "node scripts/check-railway-deploy-env.mjs",
    "railway:env-check:test": "node --test scripts/check-railway-deploy-env.test.mjs",
    "railway:mcp-query-smoke": "node scripts/railway-mcp-query-smoke.mjs",
    "railway:mcp-query-smoke:test": "node --test scripts/railway-mcp-query-smoke.test.mjs",
    "railway:sqlite-restart-smoke": "bash scripts/railway-sqlite-restart-smoke.sh",
    "read-surface:smoke": "node scripts/read-surface-smoke.mjs",
    "read-surface:smoke:test": "node --test scripts/read-surface-smoke.test.mjs",
    "//flyio": "Fly.io Core deploy gate (deploy/flyio/README.md). env-check is the offline preflight; env-check:test runs its deterministic offline tests.",
    "flyio:env:check": "node scripts/check-flyio-deploy-env.mjs",
    "flyio:env:check:test": "node --test scripts/check-flyio-deploy-env.test.mjs",
    "stream:no-human-verify": "bash scripts/run-interaction-stream-no-human-verify.sh",
    "agent-skill:check": "node scripts/sync-agent-skill.mjs --check",
    "agent-skill:sync": "node scripts/sync-agent-skill.mjs --write",
    "agent-skill:boundary-check": "node --test scripts/agent-skill-boundary.test.mjs",
    "spec:check": "node scripts/spec-check.mjs",
    "stream-debug:summary": "node scripts/stream-debug-summary.mjs",
    "workstreams:status": "node scripts/workstreams-status.mjs",
    "reference-contract:generate": "pnpm --filter @pdpp/reference-contract run generate:all",
    "reference-contract:check-generated": "pnpm --filter @pdpp/reference-contract run check:generated",
    "cli:published-help": "node scripts/cli-acceptance-smoke.mjs published-help",
    "cli:connect-smoke": "node scripts/cli-acceptance-smoke.mjs local-connect",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run --no-ci",
    "release:policy-check": "node scripts/check-package-release-policy.mjs",
    "release:policy-check:test": "node --test scripts/check-package-release-policy.test.mjs",
    "release:dist-tag-check": "node scripts/check-dist-tag-posture.mjs",
    "release:dist-tag-check:test": "node --test scripts/check-dist-tag-posture.test.mjs",
    "owner-journey:acceptance": "node scripts/check-owner-journey-acceptance.mjs",
    "owner-journey:acceptance:test": "node --test scripts/check-owner-journey-acceptance.test.mjs",
    "reference-implementation:test": "pnpm --dir reference-implementation run test",
    "reference-implementation:server": "pnpm --dir reference-implementation run server",
    "reference-implementation:server:dev": "pnpm --dir reference-implementation run dev",
    "reference-implementation:cli": "pnpm --dir reference-implementation run cli",
    "console:dev": "pnpm --dir apps/console dev",
    "console:build": "pnpm --dir apps/console build",
    "console:start": "pnpm --dir apps/console start",
    "//site:dev": "Public docs/marketing surface (apps/site): home, docs, reference, llms*, sandbox (mock-backed), planning, design, palette. No BFF, no live AS/RS. Defaults to :3001.",
    "site:dev": "pnpm --dir apps/site dev",
    "site:build": "pnpm --dir apps/site build",
    "site:start": "pnpm --dir apps/site start",
    "//dev:full": "Reference + console + site in parallel for cross-surface link verification (design.md §5).",
    "dev:full": "pnpm -r --parallel --stream --filter pdpp-reference-implementation --filter pdpp-console --filter pdpp-site run dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@pdpp/brand": "workspace:*",
    "@semantic-release/exec": "^7.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "lefthook": "^2.1.6",
    "pdpp-reference-implementation": "workspace:*",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "ultracite": "^7.6.0"
  }
}
