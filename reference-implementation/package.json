{
  "name": "pdpp-reference-implementation",
  "version": "0.1.0",
  "description": "Forkable PDPP reference implementation with AS/RS, runtime, CLI, and conformance-style tests.",
  "type": "module",
  "bin": {
    "pdpp": "./cli/index.js"
  },
  "exports": {
    "./reference-local-defaults": "./server/reference-local-defaults.ts",
    "./reference-topology": "./server/reference-topology.ts",
    "./owner-session": "./server/owner-session.ts",
    "./deployment-diagnostics": "./server/deployment-diagnostics.ts",
    "./operations/rs-streams-list": "./operations/rs-streams-list/index.ts",
    "./operations/rs-streams-detail": "./operations/rs-streams-detail/index.ts",
    "./operations/rs-schema-get": "./operations/rs-schema-get/index.ts",
    "./operations/rs-records-list": "./operations/rs-records-list/index.ts",
    "./operations/rs-records-detail": "./operations/rs-records-detail/index.ts",
    "./operations/rs-search-lexical": "./operations/rs-search-lexical/index.ts"
  },
  "scripts": {
    "//dev": "Default dev is quiet again. Use `pnpm dev:trace-gc` only when investigating native/V8 crash behavior under load. Diagnostic reports go to ../tmp/node-reports/ and exclude env/network sections so connector credentials are not persisted.",
    "dev": "sh -c 'mkdir -p ../tmp/node-reports && WEB_ORIGIN_PORT=${PDPP_WEB_PORT:-3000} && PDPP_REFERENCE_MODE=${PDPP_REFERENCE_MODE:-composed} PDPP_REFERENCE_ORIGIN=${PDPP_REFERENCE_ORIGIN:-http://localhost:$WEB_ORIGIN_PORT} PDPP_DB_PATH=${PDPP_DB_PATH:-../packages/polyfill-connectors/.pdpp-data/pdpp.sqlite} PDPP_REFERENCE_OPERATIONAL_DEFAULTS=${PDPP_REFERENCE_OPERATIONAL_DEFAULTS:-1} node --env-file-if-exists=../.env.local --report-on-fatalerror --report-uncaught-exception --report-exclude-env --report-exclude-network --report-directory=../tmp/node-reports server/index.js'",
    "dev:trace-gc": "sh -c 'mkdir -p ../tmp/node-reports && WEB_ORIGIN_PORT=${PDPP_WEB_PORT:-3000} && PDPP_REFERENCE_MODE=${PDPP_REFERENCE_MODE:-composed} PDPP_REFERENCE_ORIGIN=${PDPP_REFERENCE_ORIGIN:-http://localhost:$WEB_ORIGIN_PORT} PDPP_DB_PATH=${PDPP_DB_PATH:-../packages/polyfill-connectors/.pdpp-data/pdpp.sqlite} PDPP_REFERENCE_OPERATIONAL_DEFAULTS=${PDPP_REFERENCE_OPERATIONAL_DEFAULTS:-1} node --env-file-if-exists=../.env.local --report-on-fatalerror --report-uncaught-exception --report-exclude-env --report-exclude-network --report-directory=../tmp/node-reports --trace-gc --trace-gc-verbose server/index.js'",
    "server": "sh -c 'PDPP_REFERENCE_OPERATIONAL_DEFAULTS=${PDPP_REFERENCE_OPERATIONAL_DEFAULTS:-1} node --env-file-if-exists=../.env.local server/index.js'",
    "cli": "node cli/index.js",
    "example-client": "node examples/third-party-app/server.js",
    "test": "node scripts/run-tests.js",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "verify": "pnpm typecheck && pnpm check"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@huggingface/transformers": "^4.2.0",
    "@pdpp/reference-contract": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "express": "^4.18.3",
    "fastify": "^5.6.1",
    "pino": "^10.3.1",
    "qs": "^6.14.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "pg": "^8.20.0",
    "pino-pretty": "^13.0.0",
    "ultracite": "7.6.0"
  }
}
