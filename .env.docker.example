# Copy to .env.docker for local Docker runs, then pass it with:
#   docker compose --env-file .env.docker pull
#   docker compose --env-file .env.docker up -d
#
# Do not commit real secrets. Empty values keep the reference in open local-dev
# mode where that feature allows it.

PDPP_REFERENCE_ORIGIN=http://localhost:3002
PDPP_TRUSTED_HOSTS=
AS_PUBLIC_URL=
RS_PUBLIC_URL=
AS_ISSUER=
PDPP_WEB_BASE_URL=

# Browser-facing host port for the web container. The container still listens on
# 3000 internally; this default avoids colliding with host services on 3000/3001.
PDPP_WEB_PORT=3002

# Public images used by docker compose pull/up. Override these to test a fork,
# a version tag, a sha-* tag, or a digest-pinned image.
PDPP_REFERENCE_IMAGE=ghcr.io/vana-com/pdpp/reference:main
PDPP_WEB_IMAGE=ghcr.io/vana-com/pdpp/web:main

# Development-only: comma-separated hostnames allowed to connect to Next dev
# resources/HMR when using Docker hot reload through a LAN IP or reverse proxy.
# Examples: peregrine-dev.vivid.fish,192.168.1.180
PDPP_WEB_ALLOWED_DEV_ORIGINS=

PDPP_DB_PATH=/var/lib/pdpp/pdpp.sqlite
PDPP_EMBEDDING_CACHE_DIR=/var/cache/pdpp/transformers

# Set to 0 if you do not want first boot to download the default MiniLM model.
PDPP_EMBEDDING_DOWNLOAD_ALLOWED=1

# Optional owner/session gate for /owner, /device, /consent, and /dashboard.
PDPP_OWNER_PASSWORD=
PDPP_OWNER_SUBJECT_ID=owner_local

# Owner/operator-held key provider for the per-connection static-secret
# credential store. Required ONLY when capturing a static-secret connection's
# credential; the store fails closed (no plaintext stored) when a capture is
# attempted without it. For the simplest Docker path, generate a high-entropy
# value and keep it out of committed files, e.g.:
#   openssl rand -base64 48
# For Docker/Kubernetes secret mounts, leave the env value empty and point
# PDPP_CREDENTIAL_ENCRYPTION_KEY_FILE at the mounted secret file instead.
# Provider secrets are sealed at rest under this key and are never returned by
# any REST/MCP/console read. See
# openspec/changes/complete-self-service-connection-onboarding/design.md.
PDPP_CREDENTIAL_ENCRYPTION_KEY=
PDPP_CREDENTIAL_ENCRYPTION_KEY_FILE=

# Optional protected DCR token override. Leave empty for the reference-local default.
PDPP_DCR_INITIAL_ACCESS_TOKENS=

# Optional dashboard Web Push notifications for pending connector interactions.
# Generate local keys with:
#   pnpm --dir reference-implementation exec web-push generate-vapid-keys
PDPP_WEB_PUSH_VAPID_PUBLIC_KEY=
PDPP_WEB_PUSH_VAPID_PRIVATE_KEY=
PDPP_WEB_PUSH_VAPID_SUBJECT=mailto:pdpp-reference@example.invalid

# Optional Google Data Portability OAuth app for the API-backed Google Maps
# Data Portability source. These are deployment-level OAuth app settings, not
# per-account Google credentials and not Gmail app passwords. The redirect URI
# must exactly match the Google Cloud OAuth client and this deployment:
#   https://<your-origin>/_ref/provider-auth/callback
GOOGLE_DATAPORTABILITY_CLIENT_ID=
GOOGLE_DATAPORTABILITY_CLIENT_SECRET=
GOOGLE_DATAPORTABILITY_REDIRECT_URI=
# Optional comma-separated subset of documented Maps resource groups. Leave
# blank to request the connector's current documented Maps resource set.
GOOGLE_DATAPORTABILITY_RESOURCE_GROUPS=

# Optional connector credentials for Docker-managed live connector runs. Leave
# blank unless you are intentionally testing that connector in this local stack.
YNAB_PERSONAL_ACCESS_TOKEN=
# Backward-compatible alias accepted by the connector.
YNAB_PAT=
USAA_USERNAME=
USAA_PASSWORD=
GOOGLE_APP_PASSWORD_PDPP=
# Backward-compatible alias accepted by the connector.
GMAIL_APP_PASSWORD=
GMAIL_ADDRESS=
# Backward-compatible alias accepted by the connector.
GMAIL_USER=
# Required only when intentionally hydrating or historically backfilling Gmail
# attachment bytes. Mint an owner token from the operator deployment-token
# surface and keep it out of committed files.
PDPP_OWNER_TOKEN=
# Applies to both incremental Gmail attachment hydration and historical
# `--backfill-streams attachments` runs. Leave blank for the connector default.
PDPP_GMAIL_MAX_ATTACHMENT_BYTES=
# Historical Gmail backfill advances in bounded UID windows. Leave blank for
# the connector default.
PDPP_GMAIL_ATTACHMENT_BACKFILL_WINDOW_UIDS=
CHATGPT_USERNAME=
CHATGPT_PASSWORD=
# Diagnostic-only: when set to 1, a ChatGPT run performs one redacted
# list/detail/list side-effect probe and exits without normal collection.
PDPP_CHATGPT_SIDE_EFFECT_PROBE=
# Optional ChatGPT run guardrails. Leave blank for connector defaults; set these
# when scheduling large histories so each run stops before it can hammer ChatGPT.
PDPP_CHATGPT_MAX_DETAIL_FETCHES_PER_RUN=
PDPP_CHATGPT_MAX_RUN_WALL_CLOCK_MS=
PDPP_CHATGPT_DETAIL_RATE_LIMIT_STOP_AFTER=
# Optional local raw fixture capture for connector runs. Raw fixtures can
# contain owner data and are gitignored; scrub before committing fixtures.
PDPP_CAPTURE_FIXTURES=
NTFY_TOPIC=
NTFY_SERVER_URL=
NTFY_USERNAME=
NTFY_PASSWORD=
GITHUB_USERNAME=
GITHUB_PASSWORD=
GITHUB_PERSONAL_ACCESS_TOKEN=
SLACK_WORKSPACE=
SLACK_TOKEN=
SLACK_COOKIE=
# Optional Slack/slackdump Docker contract. The stock reference image does not
# bundle AGPL slackdump; mount a host-provided directory that contains a
# `slackdump` executable. Inside the container the stable path is:
#   /opt/pdpp-tools/slackdump/slackdump
#
# Examples:
#   PDPP_DOCKER_SLACKDUMP_DIR=/home/user/go/bin
#   PDPP_DOCKER_SLACKDUMP_DIR=./packages/polyfill-connectors/.pdpp-tools/slackdump
PDPP_DOCKER_SLACKDUMP_DIR=./packages/polyfill-connectors/.pdpp-tools/slackdump
SLACKDUMP_BIN=/opt/pdpp-tools/slackdump/slackdump
CHASE_USERNAME=
CHASE_PASSWORD=
AMAZON_USERNAME=
AMAZON_PASSWORD=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# Reserved for legacy/API-based Reddit setups; the current connector uses a
# logged-in browser session and does not require these.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Notion: internal integration token. Create at
# https://www.notion.so/my-integrations ("New integration"), then share the
# pages/databases you want the connector to read with that integration.
# Manifest is background_safe + recommended_mode=automatic; once this is set,
# enable the schedule from the dashboard (POST /_ref/connectors/<id>/schedule).
NOTION_API_TOKEN=

# Oura: personal access token from
# https://cloud.ouraring.com/personal-access-tokens
# Manifest is background_safe + automatic; same dashboard step to enable schedule.
OURA_PERSONAL_ACCESS_TOKEN=

# Strava: OAuth access token. Requires a registered Strava API application
# (https://www.strava.com/settings/api) and a manually exchanged user access
# token with at least `activity:read` scope. Manifest is background_safe +
# automatic; same dashboard step to enable schedule.
STRAVA_ACCESS_TOKEN=

# File connector Docker import contract. By default compose mounts empty local
# import directories to /imports; point these at host homes when running the
# file connectors inside Docker.
PDPP_DOCKER_CLAUDE_CODE_HOME=./packages/polyfill-connectors/.pdpp-imports/claude
PDPP_DOCKER_CODEX_HOME=./packages/polyfill-connectors/.pdpp-imports/codex
CLAUDE_CODE_HOME=/imports/claude
CLAUDE_CODE_PROJECTS_DIR=/imports/claude/projects
CODEX_HOME=/imports/codex

# Host browser bridge — opt-in for browser-backed connectors that need a
# visible host browser the operator can see and click. Leave both empty to
# use the in-container Chromium (no visible browser; suitable for headless
# flows only). See openspec/changes/design-host-browser-bridge-for-docker.
#
# macOS / Windows Docker Desktop: start the bridge with default options
#     pnpm --dir packages/polyfill-connectors exec tsx \
#       bin/host-browser-bridge.ts --profile <name>
# and copy `PDPP_HOST_BROWSER_BRIDGE_URL=ws://host.docker.internal:7670`.
#
# Linux Docker: host.docker.internal resolves to the docker bridge IP, not
# host loopback, so the bridge must bind to that IP. Discover it with:
#     DOCKER_BRIDGE_IP=$(ip -4 addr show docker0 | awk '/inet /{print $2}' | cut -d/ -f1)
# then start with `--bind-host=$DOCKER_BRIDGE_IP` and set:
#     PDPP_HOST_BROWSER_BRIDGE_URL=ws://172.17.0.1:7670  (or your bridge IP)
PDPP_HOST_BROWSER_BRIDGE_URL=
PDPP_HOST_BROWSER_BRIDGE_TOKEN=
# Set to 1 only when the bridge is intentionally pointed at the operator's
# daily Chrome (escape hatch). Off by default; emits a per-run warning.
PDPP_HOST_BROWSER_BRIDGE_DAILY_CHROME=

# ---------------------------------------------------------------------------
# Optional n.eko run-interaction streaming backend
# ---------------------------------------------------------------------------
# Start the n.eko-backed local playground with:
#   docker compose --env-file .env.docker -f docker-compose.yml -f docker-compose.neko.yml up --build
#
# Then open:
#   http://localhost:3002/dashboard/stream-playground?backend=neko
#
# The n.eko service stays on the private Compose network. The reference app
# reaches it by service DNS, and only WebRTC media mux ports are exposed to the
# host.
PDPP_ENABLE_STREAM_PLAYGROUND=1
PDPP_STREAM_PLAYGROUND_BACKEND=neko
# Private URL used by the reference service to reach n.eko.
PDPP_NEKO_BASE_URL=http://neko:8080/neko
PDPP_NEKO_PROXY_ALLOWED_HOSTS=neko:8080
PDPP_NEKO_PROXY_AUTOLOGIN=1
PDPP_STREAM_PLAYGROUND_NEKO_CDP_HTTP_URL=http://neko:9223
PDPP_NEKO_CDP_HTTP_URL=http://neko:9223
NEKO_CONTROL_USERNAME=admin
NEKO_CONTROL_PASSWORD=
NEKO_PASSWORD_ADMIN=neko
NEKO_USERNAME=user
NEKO_PASSWORD=neko
NEKO_MEMBER_PROVIDER=multiuser
NEKO_MEMBER_MULTIUSER_ADMIN_PASSWORD=
NEKO_MEMBER_MULTIUSER_USER_PASSWORD=
# Managed connector policy. ChatGPT, Chase, USAA, Amazon, and Reddit use owner-present managed
# n.eko surfaces in Docker; they remain manual-sensitive per their manifests
# and are not scheduled/background-safe just because a surface can be managed.
PDPP_NEKO_MANAGED_CONNECTORS=https://registry.pdpp.org/connectors/chatgpt,https://registry.pdpp.org/connectors/chase,https://registry.pdpp.org/connectors/usaa,https://registry.pdpp.org/connectors/amazon,https://registry.pdpp.org/connectors/reddit
PDPP_NEKO_SURFACE_MODE=dynamic
# ChatGPT is a credential-boundary connector: its managed surface process is
# retained (never stopped under routine idle TTL or capacity pressure) because its
# provider API session lives in the live browser process. Two ChatGPT connections
# retain two surfaces; cap=3 leaves exactly one fair transient slot for the other
# managed connectors. This fair-slot invariant is enforced fail-closed at
# config/boot — a cap that would let retained surfaces consume all capacity is
# rejected rather than silently starving non-retained connectors.
PDPP_NEKO_SURFACE_CAP=3
PDPP_NEKO_STATIC_PROFILE_KEY=
PDPP_NEKO_BROWSER_OWNER_MODE=neko-owned
#
# Experimental dynamic n.eko allocation. Leave these empty unless intentionally
# running the Compose `neko-dynamic` profile with a trusted allocator sidecar.
# The allocator can create sibling browser containers and mounts
# /var/run/docker.sock, which is effectively host-root equivalent. Persistent
# profile storage also retains authenticated browser state under the configured
# root; protect and back it up like credentials.
#
# To try dynamic mode, set the following together:
#   PDPP_NEKO_ALLOCATOR_URL=http://neko-allocator:7331
#   PDPP_NEKO_PROFILE_STORAGE_POLICY=persistent
#   PDPP_NEKO_PROFILE_STORAGE_ROOT=/absolute/host/path/to/neko-profiles
#   PDPP_NEKO_BASE_URL=
#   PDPP_NEKO_CDP_HTTP_URL=
#   PDPP_NEKO_STATIC_PROFILE_KEY=
# Then start with:
#   docker compose --profile neko-dynamic --env-file .env.docker -f docker-compose.yml -f docker-compose.neko.yml up --build
PDPP_NEKO_ALLOCATOR_URL=
PDPP_NEKO_PROFILE_STORAGE_POLICY=
PDPP_NEKO_PROFILE_STORAGE_ROOT=
PDPP_NEKO_READINESS_TIMEOUT_MS=
# The polished n.eko playground uses assistive CDP for user-triggered copy/paste
# helpers. Use browser-owner/strict for stealth-sensitive Patchright runs.
PDPP_NEKO_STEALTH_MODE=assistive
NEKO_IMAGE=pdpp-neko:local
NEKO_ALLOCATOR_IMAGE=pdpp-neko-allocator:local
NEKO_BASE_IMAGE=ghcr.io/m1k1o/neko/chromium:3.0@sha256:13264ee217ecccda06b07aa7543dc12d8f9a423ace344b6bda6ebf6d2ecea193
NEKO_DESKTOP_SCREEN=1280x720@30
# The baked docker/neko/neko.yaml enables main/mq/lq VP8 pipelines plus n.eko's
# estimator, so the stream can adapt bitrate without a static env override.
NEKO_WEBRTC_PORT=59000
# Dynamic allocator port and per-surface WebRTC mux port range. The profile
# root must be an absolute host path because the allocator talks to the Docker
# daemon through /var/run/docker.sock and Docker resolves bind sources on the
# host, not inside the allocator sidecar.
PDPP_NEKO_ALLOCATOR_PORT=7331
PDPP_NEKO_PROFILE_OWNER_UID=1000
PDPP_NEKO_PROFILE_OWNER_GID=1000
PDPP_NEKO_WEBRTC_HOST_PORT_START=59001
PDPP_NEKO_WEBRTC_HOST_PORT_END=59010
# Optional overrides. Defaults route n.eko HTTP and CDP over the Compose network
# by allocator-created container name while exposing only mux TCP/UDP ports to
# the host.
PDPP_NEKO_STREAM_BASE_URL_TEMPLATE=http://{container_name}:8080/neko
PDPP_NEKO_CDP_BASE_URL_TEMPLATE=http://{container_name}:9223/
# WebRTC media candidates are separate from the HTTPS/page URL. A public
# dashboard route or /neko proxy route does not make WebRTC media reachable.
#
# Fast LAN path: set this to the Docker host IP the phone can reach instead of
# 127.0.0.1, and ensure TCP/UDP NEKO_WEBRTC_PORT is allowed by the firewall.
NEKO_WEBRTC_NAT1TO1=127.0.0.1
NEKO_WEBRTC_ICESERVERS=[]
#
# Reliable WAN/LTE SLVP path: run the n.eko overlay with the `turn` profile:
#   pnpm docker:neko:turn
#
# Then set TURN_PUBLIC_IP to a public routed address for this host and set
# NEKO_WEBRTC_ICESERVERS to authenticated TURN URLs. TURN is a fallback relay:
# WebRTC will still prefer direct candidates when they work.
TURN_IMAGE=coturn/coturn:4.6.3-alpine
TURN_REALM=pdpp.local
TURN_PUBLIC_IP=127.0.0.1
TURN_PORT=3478
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
TURN_USERNAME=pdpp
TURN_PASSWORD=pdpp-turn-dev
# Example for public/WAN testing, replace host + credentials before use:
# NEKO_WEBRTC_ICESERVERS=[{"urls":["turn:203.0.113.10:3478?transport=udp","turn:203.0.113.10:3478?transport=tcp"],"username":"pdpp","credential":"pdpp-turn-dev"}]

# ---------------------------------------------------------------------------
# Profile-gated Postgres service
# ---------------------------------------------------------------------------
# The Compose `postgres` service is gated behind the `postgres` profile and is
# not started by default `docker compose up`. It backs the env-gated Postgres
# conformance/runtime proofs at
#   reference-implementation/test/connector-state-scheduler-conformance-postgres.test.js
#   reference-implementation/test/consent-device-auth-conformance-postgres.test.js
#   reference-implementation/test/postgres-runtime-storage.test.js
# The reference runtime uses SQLite by default. Runtime Postgres storage is
# opt-in and does not migrate an existing SQLite database:
#   PDPP_STORAGE_BACKEND=postgres
#   PDPP_DATABASE_URL=postgres://pdpp:pdpp@localhost:55432/pdpp_proof
#
# Start the proof service explicitly:
#   docker compose --profile postgres --env-file .env.docker up -d postgres
#
# Then run the env-gated conformance tests against it:
#   PDPP_TEST_POSTGRES_URL=postgres://pdpp:pdpp@localhost:55432/pdpp_proof \
#     node --test --test-force-exit \
#     reference-implementation/test/connector-state-scheduler-conformance-postgres.test.js \
#     reference-implementation/test/consent-device-auth-conformance-postgres.test.js \
#     reference-implementation/test/postgres-runtime-storage.test.js
#
# Stop just the proof service when done:
#   docker compose --profile postgres --env-file .env.docker stop postgres
#   docker compose --profile postgres --env-file .env.docker rm -f postgres
#
# The expected runtime image is pgvector-capable (pgvector/pgvector:pg16).
# Custom images without pgvector use a degraded JSONB vector compatibility
# fallback and are not the normal path.
PDPP_POSTGRES_IMAGE=pgvector/pgvector:pg16
# Bind host for the proof service. Defaults to loopback-only (127.0.0.1) so
# the service ships with default `pdpp/pdpp` credentials but is unreachable
# from LAN/WAN. Change this only after also changing the credentials below;
# binding to 0.0.0.0 with default credentials would expose an open Postgres
# on your network.
PDPP_POSTGRES_BIND_HOST=127.0.0.1
# Nonstandard host port to avoid colliding with operator-installed Postgres on
# 5432. Override only if 55432 is already in use.
PDPP_POSTGRES_PORT=55432
PDPP_POSTGRES_USER=pdpp
PDPP_POSTGRES_PASSWORD=pdpp
PDPP_POSTGRES_DB=pdpp_proof
