{
  "name": "@opendatalabs/remote-surface",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Host-neutral RemoteSurface abstraction layer for browser interactions over n.eko and CDP backends.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/vana-com/remote-surface#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vana-com/remote-surface.git"
  },
  "bugs": {
    "url": "https://github.com/vana-com/remote-surface/issues"
  },
  "keywords": [
    "remote-surface",
    "browser",
    "neko",
    "cdp",
    "streaming",
    "clipboard",
    "mobile-ime",
    "webrtc"
  ],
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./backends/cdp": {
      "types": "./dist/backends/cdp/index.d.ts",
      "import": "./dist/backends/cdp/index.js"
    },
    "./backends/neko": {
      "types": "./dist/backends/neko/index.d.ts",
      "import": "./dist/backends/neko/index.js"
    },
    "./backends/types": {
      "types": "./dist/backends/types.d.ts",
      "import": "./dist/backends/types.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./compat/pdpp-reference": {
      "types": "./dist/compat/pdpp-reference/index.d.ts",
      "import": "./dist/compat/pdpp-reference/index.js"
    },
    "./controllers": {
      "types": "./dist/controllers/index.d.ts",
      "import": "./dist/controllers/index.js"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics/index.d.ts",
      "import": "./dist/diagnostics/index.js"
    },
    "./ime": {
      "types": "./dist/ime/index.d.ts",
      "import": "./dist/ime/index.js"
    },
    "./leases": {
      "types": "./dist/leases/index.d.ts",
      "import": "./dist/leases/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js"
    },
    "./reference": {
      "types": "./dist/reference/index.d.ts",
      "import": "./dist/reference/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "ultracite check",
    "check:dist": "node ./scripts/check-dist-drift.mjs",
    "fix": "ultracite fix",
    "playground:dev": "tsx playground/server/index.ts",
    "playground:test": "REMOTE_SURFACE_PLAYGROUND_HEADLESS=1 playwright test -c playground/playwright.config.ts",
    "playground:typecheck": "tsc -p playground/tsconfig.json --noEmit",
    "playground:verify": "pnpm playground:typecheck && pnpm playground:test",
    "prepack": "pnpm build",
    "validate:package": "pnpm build && node ./scripts/validate-package.mjs",
    "test": "node --test --test-timeout=15000 --import tsx 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm check && pnpm test && pnpm validate:package && pnpm check:dist"
  },
  "dependencies": {
    "transformation-matrix": "^3.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@biomejs/biome": "2.4.12",
    "@types/ws": "^8.18.1",
    "patchright": "^1.59.4",
    "tsx": "^4.21.0",
    "ultracite": "7.6.0",
    "ws": "^8.20.0"
  }
}
