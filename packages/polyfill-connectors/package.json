{
  "dependencies": {
    "@databases/sqlite": "^4.0.2",
    "dotenv": "^17.4.2",
    "imapflow": "^1.3.2",
    "linkedom": "^0.18.12",
    "ofx-js": "^0.2.0",
    "p-retry": "^8.0.0",
    "patchright": "^1.59.4",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  },
  "name": "@pdpp/polyfill-connectors",
  "scripts": {
    "postinstall": "patchright install chromium",
    "bootstrap:browser": "node ./bin/pdpp-connectors.js browser bootstrap",
    "probe:browser": "node ./bin/pdpp-connectors.js browser probe",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "node --test --import tsx 'connectors/**/*.test.ts' 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm check"
  },
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Polyfill connectors for non-PDPP platforms (YNAB, Gmail, Amazon, ChatGPT, USAA).",
  "bin": {
    "pdpp-connectors": "./bin/pdpp-connectors.js"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "ultracite": "7.6.0"
  }
}
