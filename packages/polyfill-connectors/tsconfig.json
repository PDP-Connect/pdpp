{
  "compilerOptions": {
    // Language + module (Node ESM)
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "forceConsistentCasingInFileNames": true,

    // Strictness: the 2026 "strict-plus" baseline. Every flag here catches
    // a class of bug that 'strict: true' alone does not.
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    // noPropertyAccessFromIndexSignature forces process.env['X'] bracket
    // access, which Biome's useLiteralKeys rejects. Leaving off —
    // Biome's stance (prefer dot-access) matches mainstream style.
    "noPropertyAccessFromIndexSignature": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "useUnknownInCatchVariables": true,

    // Dev ergonomics — no emit, type-check only. Bundling (if ever
    // published) happens via a separate build step.
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],

    // We run .ts directly via tsx; no emitted .js to import. Biome's
    // useImportExtensions enforces explicit .ts extensions on local
    // imports, and tsx/Node strip them at load time. This matches
    // Playwright/Stripe/Vercel/vitest's convention for source-only
    // TypeScript packages.
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*.ts",
    "connectors/**/*.ts",
    "bin/**/*.ts",
    "types/**/*.d.ts"
  ],
  // __fixtures__/ holds hand-crafted HTML/JSON used by parser tests; they
  // aren't TypeScript. fixtures/ holds gitignored live captures. Tests
  // (*.test.ts) ARE included so typecheck covers them — earlier they were
  // excluded, which let test-side type errors slip through.
  "exclude": ["node_modules", "fixtures", "**/__fixtures__"]
}
