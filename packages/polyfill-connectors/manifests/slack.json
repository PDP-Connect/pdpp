{
  "protocol_version": "0.1.0",
  "connector_id": "https://registry.pdpp.org/connectors/slack",
  "version": "0.2.0",
  "display_name": "Slack",
  "runtime_requirements": {
    "bindings": { "network": { "required": true }, "filesystem": { "required": true } }
  },
  "capabilities": { "human_interaction": ["credentials"] },
  "streams": [
    {
      "name": "workspace",
      "description": "Authenticated Slack workspace: team identity, authenticated user/bot identity, enterprise affiliation, primary URL.",
      "display": {
        "label": "Slack workspace",
        "detail": "Workspace name, domain, team ID, the authenticated user (whose session this is), and enterprise parent (if any)."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id":                     { "type": "string" },
          "name":                   { "type": ["string", "null"] },
          "domain":                 { "type": ["string", "null"] },
          "email_domain":           { "type": ["string", "null"] },
          "enterprise_id":          { "type": ["string", "null"] },
          "enterprise_name":        { "type": ["string", "null"] },
          "url":                    { "type": ["string", "null"] },
          "icon_url":               { "type": ["string", "null"] },
          "authenticated_user_id":  { "type": ["string", "null"] },
          "authenticated_username": { "type": ["string", "null"] },
          "authenticated_bot_id":   { "type": ["string", "null"] },
          "fetched_at":             { "type": "string" }
        },
        "required": ["id"]
      },
      "primary_key": ["id"],
      "cursor_field": "fetched_at",
      "selection": { "fields": true, "resources": true },
      "incremental": true
    },
    {
      "name": "channels",
      "description": "Public/private channels, DMs, and group DMs visible to the authenticated user.",
      "display": {
        "label": "Your Slack channels",
        "detail": "Channel name, type flags (is_im/is_mpim/is_private/is_shared/is_archived), creator, topic and purpose (with last-set time), member count, created-at."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id":                   { "type": "string" },
          "name":                 { "type": ["string", "null"] },
          "name_normalized":      { "type": ["string", "null"] },
          "is_channel":           { "type": ["boolean", "null"] },
          "is_group":             { "type": ["boolean", "null"] },
          "is_im":                { "type": ["boolean", "null"] },
          "is_mpim":              { "type": ["boolean", "null"] },
          "is_private":           { "type": ["boolean", "null"] },
          "is_shared":            { "type": ["boolean", "null"] },
          "is_ext_shared":        { "type": ["boolean", "null"] },
          "is_org_shared":        { "type": ["boolean", "null"] },
          "is_archived":          { "type": ["boolean", "null"] },
          "is_general":           { "type": ["boolean", "null"] },
          "is_member":            { "type": ["boolean", "null"] },
          "is_read_only":         { "type": ["boolean", "null"] },
          "creator":              { "type": ["string", "null"] },
          "created":              { "type": ["integer", "null"] },
          "created_at":           { "type": ["string", "null"] },
          "topic":                { "type": ["string", "null"] },
          "topic_creator":        { "type": ["string", "null"] },
          "topic_last_set":       { "type": ["integer", "null"] },
          "purpose":              { "type": ["string", "null"] },
          "purpose_creator":      { "type": ["string", "null"] },
          "purpose_last_set":     { "type": ["integer", "null"] },
          "num_members":          { "type": ["integer", "null"] },
          "user":                 { "type": ["string", "null"] },
          "shared_team_ids":      { "type": ["array", "null"], "items": { "type": "string" } },
          "context_team_id":      { "type": ["string", "null"] },
          "previous_names":       { "type": ["array", "null"], "items": { "type": "string" } },
          "has_canvas":           { "type": ["boolean", "null"] },
          "canvas_file_id":       { "type": ["string", "null"] },
          "posting_restricted":   { "type": ["boolean", "null"] },
          "threads_restricted":   { "type": ["boolean", "null"] }
        },
        "required": ["id"]
      },
      "primary_key": ["id"],
      "cursor_field": "created",
      "selection": { "fields": true, "resources": true },
      "incremental": true
    },
    {
      "name": "channel_memberships",
      "description": "Channel ↔ user edges where slackdump could enumerate members.",
      "display": {
        "label": "Channel memberships",
        "detail": "For each channel we could see the membership of, one row per user. Includes DMs (channel member is the DM counterpart)."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id":          { "type": "string" },
          "channel_id":  { "type": "string" },
          "user_id":     { "type": "string" },
          "fetched_at":  { "type": "string" }
        },
        "required": ["id", "channel_id", "user_id"]
      },
      "primary_key": ["id"],
      "selection": { "fields": true, "resources": true },
      "incremental": false,
      "relationships": [
        { "name": "channel", "stream": "channels", "foreign_key": "channel_id", "cardinality": "has_one" },
        { "name": "user",    "stream": "users",    "foreign_key": "user_id",    "cardinality": "has_one" }
      ]
    },
    {
      "name": "users",
      "description": "Users (human + bot) visible to the authenticated principal.",
      "display": {
        "label": "People and bots in your Slack workspace",
        "detail": "Username, real name, display name, email (when visible), timezone, bot flag, admin/owner flags, deletion status."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id":                     { "type": "string" },
          "team_id":                { "type": ["string", "null"] },
          "name":                   { "type": ["string", "null"] },
          "real_name":              { "type": ["string", "null"] },
          "real_name_normalized":   { "type": ["string", "null"] },
          "display_name":           { "type": ["string", "null"] },
          "display_name_normalized":{ "type": ["string", "null"] },
          "first_name":             { "type": ["string", "null"] },
          "last_name":              { "type": ["string", "null"] },
          "email":                  { "type": ["string", "null"] },
          "phone":                  { "type": ["string", "null"] },
          "title":                  { "type": ["string", "null"] },
          "status_text":            { "type": ["string", "null"] },
          "status_emoji":           { "type": ["string", "null"] },
          "status_expiration":      { "type": ["integer", "null"] },
          "tz":                     { "type": ["string", "null"] },
          "tz_label":               { "type": ["string", "null"] },
          "tz_offset":              { "type": ["integer", "null"] },
          "color":                  { "type": ["string", "null"] },
          "is_bot":                 { "type": ["boolean", "null"] },
          "is_admin":               { "type": ["boolean", "null"] },
          "is_owner":               { "type": ["boolean", "null"] },
          "is_primary_owner":       { "type": ["boolean", "null"] },
          "is_restricted":          { "type": ["boolean", "null"] },
          "is_ultra_restricted":    { "type": ["boolean", "null"] },
          "is_stranger":            { "type": ["boolean", "null"] },
          "is_invited_user":        { "type": ["boolean", "null"] },
          "is_app_user":            { "type": ["boolean", "null"] },
          "deleted":                { "type": ["boolean", "null"] },
          "has_2fa":                { "type": ["boolean", "null"] },
          "two_factor_type":        { "type": ["string", "null"] },
          "image_192_url":          { "type": ["string", "null"] },
          "enterprise_id":          { "type": ["string", "null"] },
          "updated":                { "type": ["integer", "null"] }
        },
        "required": ["id"]
      },
      "primary_key": ["id"],
      "cursor_field": "updated",
      "selection": { "fields": true, "resources": true },
      "incremental": true
    },
    {
      "name": "messages",
      "description": "All messages across visible channels. Thread structure preserved via thread_ts. Slack marks deletions with subtype='tombstone' so messages stream is effectively mutable despite the append-only semantic class.",
      "display": {
        "label": "Your Slack messages",
        "detail": "Channel, author, timestamp, text, thread parent, reply count + reply_user_ids (who replied), edited-at, client_msg_id (dedup), subtype (joins/leaves/bot/tombstone), pinned status, block-kit metadata."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id":                     { "type": "string" },
          "channel_id":             { "type": "string" },
          "user_id":                { "type": ["string", "null"] },
          "bot_id":                 { "type": ["string", "null"] },
          "team_id":                { "type": ["string", "null"] },
          "client_msg_id":          { "type": ["string", "null"] },
          "ts":                     { "type": "string" },
          "sent_at":                { "type": "string" },
          "thread_ts":              { "type": ["string", "null"] },
          "parent_user_id":         { "type": ["string", "null"] },
          "is_thread_parent":       { "type": ["boolean", "null"] },
          "reply_count":            { "type": ["integer", "null"] },
          "reply_user_ids":         { "type": ["array", "null"], "items": { "type": "string" } },
          "latest_reply":           { "type": ["string", "null"] },
          "subtype":                { "type": ["string", "null"] },
          "is_tombstone":           { "type": ["boolean", "null"] },
          "text":                   { "type": ["string", "null"] },
          "edited_ts":              { "type": ["string", "null"] },
          "edited_by":              { "type": ["string", "null"] },
          "has_files":              { "type": ["boolean", "null"] },
          "file_count":             { "type": ["integer", "null"] },
          "has_attachments":        { "type": ["boolean", "null"] },
          "attachment_count":       { "type": ["integer", "null"] },
          "has_blocks":             { "type": ["boolean", "null"] },
          "reaction_count":         { "type": ["integer", "null"] },
          "is_pinned":              { "type": ["boolean", "null"] },
          "pinned_to":              { "type": ["array", "null"], "items": { "type": "string" } },
          "metadata_event_type":    { "type": ["string", "null"] }
        },
        "required": ["id", "channel_id", "ts"]
      },
      "primary_key": ["id"],
      "cursor_field": "ts",
      "consent_time_field": "sent_at",
      "selection": { "fields": true, "resources": true },
      "incremental": true,
      "relationships": [
        { "name": "channel", "stream": "channels", "foreign_key": "channel_id", "cardinality": "has_one" },
        { "name": "author",  "stream": "users",    "foreign_key": "user_id",    "cardinality": "has_one" }
      ]
    },
    {
      "name": "message_attachments",
      "description": "Link-preview unfurls and bot-generated rich attachments inlined on messages. One row per (message, attachment index).",
      "display": {
        "label": "Link previews and message attachments",
        "detail": "Unfurled links (URL, title, description, source service, thumbnail) and bot-generated rich attachments on messages."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id":            { "type": "string" },
          "message_id":    { "type": "string" },
          "channel_id":    { "type": "string" },
          "index":         { "type": "integer" },
          "fallback":      { "type": ["string", "null"] },
          "service_name":  { "type": ["string", "null"] },
          "service_icon":  { "type": ["string", "null"] },
          "title":         { "type": ["string", "null"] },
          "title_link":    { "type": ["string", "null"] },
          "text":          { "type": ["string", "null"] },
          "from_url":      { "type": ["string", "null"] },
          "image_url":     { "type": ["string", "null"] },
          "thumb_url":     { "type": ["string", "null"] },
          "author_name":   { "type": ["string", "null"] },
          "author_link":   { "type": ["string", "null"] },
          "color":         { "type": ["string", "null"] }
        },
        "required": ["id", "message_id", "channel_id", "index"]
      },
      "primary_key": ["id"],
      "selection": { "fields": true, "resources": true },
      "incremental": false,
      "relationships": [
        { "name": "message", "stream": "messages", "foreign_key": "message_id", "cardinality": "has_one" }
      ]
    },
    {
      "name": "reactions",
      "description": "Reactions as (message, emoji, user) triples.",
      "display": {
        "label": "Slack reactions",
        "detail": "One row per (message, emoji, user). Emoji name, reacting user, reacted-to message."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id":          { "type": "string" },
          "message_id":  { "type": "string" },
          "channel_id":  { "type": "string" },
          "user_id":     { "type": "string" },
          "emoji":       { "type": "string" }
        },
        "required": ["id", "message_id", "channel_id", "user_id", "emoji"]
      },
      "primary_key": ["id"],
      "selection": { "fields": true, "resources": true },
      "incremental": false,
      "relationships": [
        { "name": "message", "stream": "messages", "foreign_key": "message_id", "cardinality": "has_one" },
        { "name": "user",    "stream": "users",    "foreign_key": "user_id",    "cardinality": "has_one" }
      ]
    },
    {
      "name": "files",
      "description": "File attachments referenced in messages. Metadata only by default.",
      "display": {
        "label": "Files shared in Slack",
        "detail": "Filename, mimetype, size, upload time, uploader, public/private flags, title."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id":                { "type": "string" },
          "name":              { "type": ["string", "null"] },
          "title":             { "type": ["string", "null"] },
          "mimetype":          { "type": ["string", "null"] },
          "filetype":          { "type": ["string", "null"] },
          "pretty_type":       { "type": ["string", "null"] },
          "size":              { "type": ["integer", "null"] },
          "created":           { "type": ["integer", "null"] },
          "created_at":        { "type": ["string", "null"] },
          "uploader_id":       { "type": ["string", "null"] },
          "is_public":         { "type": ["boolean", "null"] },
          "is_external":       { "type": ["boolean", "null"] },
          "is_starred":        { "type": ["boolean", "null"] },
          "external_type":     { "type": ["string", "null"] },
          "mode":              { "type": ["string", "null"] },
          "permalink":         { "type": ["string", "null"] },
          "url_private":       { "type": ["string", "null"] },
          "original_w":        { "type": ["integer", "null"] },
          "original_h":        { "type": ["integer", "null"] }
        },
        "required": ["id"]
      },
      "primary_key": ["id"],
      "cursor_field": "created",
      "selection": { "fields": true, "resources": true },
      "incremental": true
    }
  ],
  "profiles": [
    {
      "id": "full",
      "label": "Your complete Slack history",
      "streams": [
        { "name": "workspace" },
        { "name": "channels" },
        { "name": "channel_memberships" },
        { "name": "users" },
        { "name": "messages" },
        { "name": "message_attachments" },
        { "name": "reactions" },
        { "name": "files" }
      ]
    },
    {
      "id": "messages_only",
      "label": "Messages and people, no files",
      "streams": [
        { "name": "workspace" },
        { "name": "channels" },
        { "name": "users" },
        { "name": "messages" }
      ]
    },
    {
      "id": "directory",
      "label": "Directory only (no message content)",
      "streams": [
        { "name": "workspace" },
        { "name": "channels" },
        { "name": "users" }
      ]
    }
  ]
}
