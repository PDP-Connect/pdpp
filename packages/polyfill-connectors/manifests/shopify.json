{
  "protocol_version": "0.1.0",
  "connector_id": "https://registry.pdpp.org/connectors/shopify",
  "connector_key": "shopify",
  "manifest_uri": "https://registry.pdpp.org/connectors/shopify",
  "version": "0.1.0",
  "display_name": "Shopify Shop",
  "runtime_requirements": {
    "bindings": {
      "network": {
        "required": true
      },
      "browser": {
        "required": true
      }
    }
  },
  "capabilities": {
    "human_interaction": [
      "manual_action"
    ],
    "refresh_policy": {
      "recommended_mode": "manual",
      "minimum_interval_seconds": 3600,
      "interaction_posture": "manual_action_likely",
      "rate_limit_sensitivity": "medium",
      "bot_detection_sensitivity": "high",
      "background_safe": false,
      "rationale": "Shopify Shop order history requires a logged-in browser session; refresh manually."
    },
    "public_listing": {
      "listed": false,
      "status": "unproven"
    }
  },
  "streams": [
    {
      "name": "orders",
      "description": "Orders placed across merchants via the Shop app.",
      "display": {
        "label": "Your Shop app orders",
        "detail": "Order date, merchant, items, prices, shipping status, tracking numbers, payment summary."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "order_date": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "x_pdpp_role": "event-time"
          },
          "merchant_name": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "primary-title"
          },
          "status": {
            "type": [
              "string",
              "null"
            ]
          },
          "total_cents": {
            "type": [
              "integer",
              "null"
            ]
          },
          "currency": {
            "type": [
              "string",
              "null"
            ]
          },
          "tracking_number": {
            "type": [
              "string",
              "null"
            ]
          },
          "tracking_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "item_count": {
            "type": [
              "integer",
              "null"
            ]
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "order_date",
      "consent_time_field": "order_date",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "query": {
        "search": {
          "lexical_fields": [
            "merchant_name"
          ]
        },
        "range_filters": {
          "order_date": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "order_date"
          ],
          "group_by": [
            "status",
            "currency"
          ]
        }
      },
      "coverage_strategy": "checkpoint_window",
      "freshness_strategy": "manual_as_of"
    }
  ]
}
