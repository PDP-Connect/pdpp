{
  "protocol_version": "0.1.0",
  "connector_id": "https://registry.pdpp.org/connectors/usaa",
  "connector_key": "usaa",
  "manifest_uri": "https://registry.pdpp.org/connectors/usaa",
  "version": "0.1.0",
  "display_name": "USAA",
  "runtime_requirements": {
    "bindings": {
      "network": {
        "required": true
      },
      "browser": {
        "required": true
      }
    }
  },
  "capabilities": {
    "human_interaction": [
      "manual_action"
    ],
    "refresh_policy": {
      "recommended_mode": "manual",
      "minimum_interval_seconds": 7200,
      "maximum_staleness_seconds": 86400,
      "interaction_posture": "manual_action_likely",
      "rate_limit_sensitivity": "medium",
      "bot_detection_sensitivity": "high",
      "background_safe": false,
      "rationale": "USAA requires interactive login and short sessions; refresh manually so the owner is present."
    },
    "public_listing": {
      "listed": true,
      "status": "needs_human_auth"
    }
  },
  "streams": [
    {
      "name": "accounts",
      "description": "USAA retail accounts (checking, savings, credit cards, loans). Identity and settings only; point-in-time balances are in the `account_stats` observation stream.",
      "display": {
        "label": "Your USAA accounts",
        "detail": "Account names, types, last-four, and open/closed status. Current and historical balances are in the daily `account_stats` stream."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "primary-title"
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_four": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": [
              "string",
              "null"
            ]
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "x_pdpp_role": "event-time"
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": false,
      "query": {
        "search": {
          "lexical_fields": [
            "name",
            "type",
            "status"
          ]
        },
        "range_filters": {}
      }
    },
    {
      "name": "account_stats",
      "description": "Daily balance snapshot for each USAA account, keyed by {account_id}:{YYYY-MM-DD} (UTC). One record per account per calendar day; re-running on the same day with the same balances is idempotent. Preserves a balance time series without creating false entity-version churn on the accounts stream.",
      "display": {
        "label": "Your USAA account balances (daily)",
        "detail": "Daily snapshot of balance and available balance (cents). Each record covers one calendar day for one account."
      },
      "semantics": "append",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "account_id": {
            "type": "string"
          },
          "observed_on": {
            "type": "string",
            "format": "date",
            "x_pdpp_role": "event-time"
          },
          "balance_cents": {
            "type": [
              "integer",
              "null"
            ],
            "x_pdpp_role": "amount"
          },
          "available_balance_cents": {
            "type": [
              "integer",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "account_id",
          "observed_on"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "observed_on",
      "consent_time_field": "observed_on",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "account",
          "stream": "accounts",
          "foreign_key": "account_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {},
        "range_filters": {
          "observed_on": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "balance_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "available_balance_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "observed_on"
          ]
        }
      }
    },
    {
      "name": "transactions",
      "description": "USAA transactions. Primary key is a stable synthetic hash of (account_id, date, amount, original_description, ordinal-within-tuple) because USAA's CSV export does not expose transaction IDs. Amounts are in cents (integer, signed). Transactions come from two provenances: the 18-month CSV export (`source: 'csv_export'`) and parsed statement PDFs for older history (`source: 'pdf_statement_<YYYY-MM>'`). Because the id-hash input is identical across both paths, a CSV and a PDF record of the same logical transaction collapse to the same id on ingest.",
      "display": {
        "label": "Your USAA transactions",
        "detail": "Date, signed amount in cents, cleaned payee name, original statement description, USAA-assigned category, check number (parsed from original description), and running balance when available. Pending transactions included if visible."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "account_id": {
            "type": "string"
          },
          "account_name": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "actor"
          },
          "date": {
            "type": "string",
            "format": "date",
            "x_pdpp_role": "event-time"
          },
          "amount": {
            "type": "integer"
          },
          "currency": {
            "type": "string"
          },
          "description": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "primary-title"
          },
          "original_description": {
            "type": [
              "string",
              "null"
            ]
          },
          "category": {
            "type": [
              "string",
              "null"
            ]
          },
          "check_number": {
            "type": [
              "string",
              "null"
            ]
          },
          "balance_after_cents": {
            "type": [
              "integer",
              "null"
            ]
          },
          "source": {
            "type": "string"
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "account_id",
          "date",
          "amount",
          "currency"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "date",
      "consent_time_field": "date",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "account",
          "stream": "accounts",
          "foreign_key": "account_id",
          "cardinality": "has_one"
        }
      ],
      "views": [
        {
          "id": "reconciliation",
          "label": "Fields for matching to YNAB/Amazon",
          "fields": [
            "id",
            "account_id",
            "account_name",
            "date",
            "amount",
            "description",
            "original_description",
            "category",
            "check_number"
          ]
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "account_name",
            "description",
            "original_description",
            "category",
            "source"
          ],
          "semantic_fields": [
            "description",
            "original_description"
          ]
        },
        "range_filters": {
          "date": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "amount": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "balance_after_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "sum": [
            "amount",
            "balance_after_cents"
          ],
          "min": [
            "date",
            "amount",
            "balance_after_cents"
          ],
          "max": [
            "date",
            "amount",
            "balance_after_cents"
          ],
          "group_by": [
            "currency",
            "category"
          ],
          "group_by_time": [
            "date"
          ]
        }
      }
    },
    {
      "name": "statements",
      "description": "Statement index per account. Always includes title, delivery date, and account reference. When the connector successfully hydrates a statement PDF (by driving the 'Options → Download' menu on /my/documents), the row additionally carries `document_url` (file:// URI of the stored PDF), `pdf_path` (absolute on-disk path), and `pdf_sha256` (content hash). The PDFs themselves are stored under ~/.pdpp/usaa-statements/<account_slug>/<YYYY-MM>-<sha8>.pdf — per owner direction the archive is persistent, not scratch.",
      "display": {
        "label": "Your USAA statements",
        "detail": "Monthly statements across all accounts: document title, delivery date, and account reference. PDF download URL, local path, and content hash are populated when blob hydration has run; otherwise null."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "account_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "FK to accounts.id. Resolved by matching the document row's account column (last-four first, then account name) back to the accounts stream. Null when neither match succeeds."
          },
          "title": {
            "type": "string",
            "x_pdpp_role": "primary-title"
          },
          "date_delivered": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "account_reference": {
            "type": [
              "string",
              "null"
            ]
          },
          "document_url": {
            "type": [
              "string",
              "null"
            ],
            "description": "file:// URI for the stored PDF on disk. Populated only after blob hydration; null on index-only scrapes."
          },
          "pdf_path": {
            "type": [
              "string",
              "null"
            ],
            "description": "Absolute filesystem path of the downloaded PDF under ~/.pdpp/usaa-statements/. Null until hydrated."
          },
          "pdf_sha256": {
            "type": [
              "string",
              "null"
            ],
            "description": "SHA-256 of the downloaded PDF bytes (raw blob content-address, not the content fingerprint — re-encrypted per download, so it churns on no-op re-fetches). Populated only after blob hydration; null on index-only scrapes."
          },
          "pdf_text_sha256": {
            "type": [
              "string",
              "null"
            ],
            "description": "Positive content fingerprint: SHA-256 of the statement's extracted PDF text after deterministic normalization (NFC, whitespace collapse, trim). Stable across raw-byte churn so a re-download with unchanged content is provably a no-op. Null when text extraction failed or returned empty text."
          },
          "pdf_page_count": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Integer page count from the PDF structure. A structural content invariant alongside pdf_text_sha256. Null when extraction failed."
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "x_pdpp_role": "event-time"
          }
        },
        "required": [
          "id",
          "title"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "date_delivered",
      "consent_time_field": "date_delivered",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "account",
          "stream": "accounts",
          "foreign_key": "account_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "title",
            "account_reference"
          ],
          "semantic_fields": [
            "title"
          ]
        },
        "range_filters": {
          "date_delivered": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "date_delivered"
          ]
        }
      }
    },
    {
      "name": "inbox_messages",
      "description": "Bank-generated messages in the USAA secure inbox.",
      "display": {
        "label": "Your USAA inbox",
        "detail": "Messages from USAA (statement alerts, new documents, service notices). Read/unread status and previews captured; full message bodies deferred."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "date_received": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "status": {
            "type": [
              "string",
              "null"
            ]
          },
          "subject": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "primary-title"
          },
          "preview": {
            "type": [
              "string",
              "null"
            ]
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "x_pdpp_role": "event-time"
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "date_received",
      "consent_time_field": "date_received",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "query": {
        "search": {
          "lexical_fields": [
            "subject",
            "preview",
            "status"
          ],
          "semantic_fields": [
            "subject",
            "preview"
          ]
        },
        "range_filters": {
          "date_received": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "date_received"
          ]
        }
      }
    },
    {
      "name": "credit_card_billing",
      "description": "Per-credit-card identity and settings: nickname, credit limit, APRs, card holders. Point-in-time balances, available credit, rewards, and cycle billing status are in the `credit_card_billing_stats` observation stream.",
      "display": {
        "label": "Your credit card billing details",
        "detail": "For each USAA-issued credit card: nickname, credit limit, APRs, and card holder names. Current and historical balances, available credit, rewards, and minimum-payment status are in the daily `credit_card_billing_stats` stream."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "account_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "account_nickname": {
            "type": [
              "string",
              "null"
            ]
          },
          "credit_limit_cents": {
            "type": [
              "integer",
              "null"
            ]
          },
          "annual_percent_rate": {
            "type": [
              "string",
              "null"
            ]
          },
          "cash_advance_apr": {
            "type": [
              "string",
              "null"
            ]
          },
          "card_holders": {
            "type": [
              "string",
              "null"
            ]
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "x_pdpp_role": "event-time"
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": false,
      "relationships": [
        {
          "name": "account",
          "stream": "accounts",
          "foreign_key": "account_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "account_nickname"
          ]
        },
        "range_filters": {
          "credit_limit_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    },
    {
      "name": "credit_card_billing_stats",
      "description": "Daily per-cycle billing snapshot for each credit card, keyed by {card_id}:{YYYY-MM-DD} (UTC). One record per card per calendar day; re-running on the same day with the same values is idempotent. Preserves a balance/rewards/billing-status time series without creating false entity-version churn on the credit_card_billing stream.",
      "display": {
        "label": "Your credit card balances (daily)",
        "detail": "Daily snapshot of current balance, available credit, cash rewards (cents), and the cycle billing status / minimum-payment-met flag. Each record covers one calendar day for one card."
      },
      "semantics": "append",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "card_id": {
            "type": "string"
          },
          "account_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "observed_on": {
            "type": "string",
            "format": "date",
            "x_pdpp_role": "event-time"
          },
          "current_balance_cents": {
            "type": [
              "integer",
              "null"
            ],
            "x_pdpp_role": "amount"
          },
          "available_credit_cents": {
            "type": [
              "integer",
              "null"
            ]
          },
          "cash_rewards_cents": {
            "type": [
              "integer",
              "null"
            ]
          },
          "billing_status": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "secondary"
          },
          "minimum_payment_met": {
            "type": [
              "boolean",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "card_id",
          "observed_on"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "observed_on",
      "consent_time_field": "observed_on",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "card",
          "stream": "credit_card_billing",
          "foreign_key": "card_id",
          "cardinality": "has_one"
        },
        {
          "name": "account",
          "stream": "accounts",
          "foreign_key": "account_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "billing_status"
          ]
        },
        "range_filters": {
          "observed_on": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "current_balance_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "available_credit_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "cash_rewards_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "observed_on"
          ]
        }
      }
    }
  ],
  "profiles": [
    {
      "id": "reconciliation",
      "label": "Accounts + transactions for YNAB reconciliation",
      "streams": [
        {
          "name": "accounts"
        },
        {
          "name": "transactions",
          "view": "reconciliation"
        }
      ]
    }
  ]
}
