{
  "protocol_version": "0.1.0",
  "connector_id": "https://registry.pdpp.org/connectors/heb",
  "connector_key": "heb",
  "manifest_uri": "https://registry.pdpp.org/connectors/heb",
  "version": "0.1.0",
  "display_name": "H-E-B",
  "runtime_requirements": {
    "bindings": {
      "network": {
        "required": true
      },
      "browser": {
        "required": true
      }
    }
  },
  "capabilities": {
    "human_interaction": [
      "manual_action"
    ],
    "refresh_policy": {
      "recommended_mode": "manual",
      "minimum_interval_seconds": 3600,
      "interaction_posture": "manual_action_likely",
      "rate_limit_sensitivity": "medium",
      "bot_detection_sensitivity": "high",
      "background_safe": false,
      "rationale": "H-E-B order history is browser-scraped; treat as manual to avoid lockouts and 2FA loops."
    },
    "public_listing": {
      "listed": false,
      "status": "unproven"
    }
  },
  "streams": [
    {
      "name": "orders",
      "description": "H-E-B curbside/delivery orders (in-store purchases not included).",
      "display": {
        "label": "Your H-E-B orders",
        "detail": "Order date, total, store, delivery vs curbside, item count."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "order_date": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "x_pdpp_role": "event-time"
          },
          "store": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": [
              "string",
              "null"
            ]
          },
          "method": {
            "type": [
              "string",
              "null"
            ]
          },
          "total_cents": {
            "type": [
              "integer",
              "null"
            ]
          },
          "item_count": {
            "type": [
              "integer",
              "null"
            ]
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "order_date",
      "consent_time_field": "order_date",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "query": {
        "search": {
          "lexical_fields": [
            "store"
          ]
        },
        "range_filters": {
          "order_date": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "order_date"
          ],
          "group_by": [
            "status",
            "method"
          ]
        }
      }
    },
    {
      "name": "order_items",
      "description": "Items within H-E-B orders, with nutrition when available.",
      "display": {
        "label": "Your H-E-B items",
        "detail": "Product name, UPC, quantity, price, nutrition facts from USDA if matched."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "order_id": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "x_pdpp_role": "primary-title"
          },
          "upc": {
            "type": [
              "string",
              "null"
            ]
          },
          "quantity": {
            "type": [
              "number",
              "null"
            ]
          },
          "unit_price_cents": {
            "type": [
              "integer",
              "null"
            ]
          },
          "department": {
            "type": [
              "string",
              "null"
            ]
          },
          "nutrition": {
            "type": [
              "object",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "order_id",
          "name"
        ]
      },
      "primary_key": [
        "id"
      ],
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "order",
          "stream": "orders",
          "foreign_key": "order_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "name"
          ]
        }
      }
    }
  ]
}
