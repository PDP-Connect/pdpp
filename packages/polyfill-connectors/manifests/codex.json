{
  "protocol_version": "0.1.0",
  "connector_id": "https://registry.pdpp.org/connectors/codex",
  "version": "0.3.0",
  "display_name": "OpenAI Codex CLI",
  "runtime_requirements": {
    "bindings": {
      "filesystem": {
        "required": true
      }
    }
  },
  "capabilities": {
    "human_interaction": []
  },
  "streams": [
    {
      "name": "sessions",
      "description": "Codex CLI sessions. Canonical metadata comes from ~/.codex/state_5.sqlite#threads (title, archived, tokens_used, first_user_message, sandbox_policy, approval_mode), enriched with message/tool-call counts from the on-disk rollout JSONL.",
      "display": {
        "label": "Your Codex CLI sessions",
        "detail": "Title, working directory, git commit/branch, model provider, CLI version, approval mode, sandbox policy, token usage, and counts."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "cwd": {
            "type": [
              "string",
              "null"
            ]
          },
          "originator": {
            "type": [
              "string",
              "null"
            ]
          },
          "cli_version": {
            "type": [
              "string",
              "null"
            ]
          },
          "model_provider": {
            "type": [
              "string",
              "null"
            ]
          },
          "git_commit": {
            "type": [
              "string",
              "null"
            ]
          },
          "git_branch": {
            "type": [
              "string",
              "null"
            ]
          },
          "repository_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "started_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "last_event_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "message_count": {
            "type": [
              "integer",
              "null"
            ]
          },
          "function_call_count": {
            "type": [
              "integer",
              "null"
            ]
          },
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "archived": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "tokens_used": {
            "type": [
              "integer",
              "null"
            ]
          },
          "first_user_message": {
            "type": [
              "string",
              "null"
            ]
          },
          "sandbox_policy": {
            "type": [
              "string",
              "null"
            ]
          },
          "approval_mode": {
            "type": [
              "string",
              "null"
            ]
          },
          "rollout_path": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "last_event_at",
      "consent_time_field": "started_at",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "query": {
        "search": {
          "lexical_fields": [
            "cwd",
            "originator",
            "model_provider",
            "git_branch",
            "title",
            "first_user_message",
            "sandbox_policy",
            "approval_mode"
          ],
          "semantic_fields": [
            "title",
            "first_user_message"
          ]
        },
        "range_filters": {
          "started_at": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "last_event_at": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "message_count": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "function_call_count": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "tokens_used": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    },
    {
      "name": "messages",
      "description": "Messages within Codex sessions: user prompts, assistant responses, and reasoning placeholders.",
      "display": {
        "label": "Your Codex messages",
        "detail": "Role (user/assistant), text content, timestamp, session reference. Reasoning traces are referenced but content is encrypted and not stored."
      },
      "semantics": "append_only",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "role": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          },
          "content": {
            "type": [
              "string",
              "null"
            ]
          },
          "timestamp": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "session_id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "timestamp",
      "consent_time_field": "timestamp",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "session",
          "stream": "sessions",
          "foreign_key": "session_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "role",
            "type",
            "content"
          ],
          "semantic_fields": [
            "content"
          ]
        },
        "range_filters": {
          "timestamp": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    },
    {
      "name": "function_calls",
      "description": "Tool invocations and their outputs (shell commands, file ops) recorded in Codex sessions.",
      "display": {
        "label": "Codex tool calls",
        "detail": "Tool name, arguments, call_id, and output preview. Includes shell commands Codex ran and their results."
      },
      "semantics": "append_only",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "call_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          },
          "arguments": {
            "type": [
              "string",
              "null"
            ]
          },
          "output_preview": {
            "type": [
              "string",
              "null"
            ]
          },
          "timestamp": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "session_id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "timestamp",
      "consent_time_field": "timestamp",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "session",
          "stream": "sessions",
          "foreign_key": "session_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "name",
            "arguments",
            "output_preview"
          ],
          "semantic_fields": [
            "arguments",
            "output_preview"
          ]
        },
        "range_filters": {
          "timestamp": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    },
    {
      "name": "rules",
      "description": "Personal trust-registry rules recorded in ~/.codex/rules/*.rules \u2014 the de-facto log of approval decisions. One record per rule line. The stream is named `rules` to match the real local directory; `approval_rules` was backlog shorthand, not an on-disk source name.",
      "display": {
        "label": "Your Codex approval rules",
        "detail": "Each rule line (e.g. prefix_rule / decision=allow) from your .rules files, with ruleset and position."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "ruleset": {
            "type": "string"
          },
          "rule_text": {
            "type": "string"
          },
          "rule_index": {
            "type": "integer"
          },
          "path": {
            "type": [
              "string",
              "null"
            ]
          },
          "mtime_epoch": {
            "type": [
              "integer",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "ruleset",
          "rule_text",
          "rule_index"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "mtime_epoch",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": false,
      "query": {
        "search": {
          "lexical_fields": [
            "ruleset",
            "rule_text",
            "path"
          ],
          "semantic_fields": [
            "rule_text"
          ]
        },
        "range_filters": {
          "mtime_epoch": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    },
    {
      "name": "prompts",
      "description": "User-authored prompt templates from ~/.codex/prompts/*.md. Frontmatter (name, description) is parsed; body is the prompt content.",
      "display": {
        "label": "Your Codex prompts",
        "detail": "Name, description, body, and source path for each prompt template."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "content": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "type": [
              "string",
              "null"
            ]
          },
          "mtime_epoch": {
            "type": [
              "integer",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "mtime_epoch",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": false,
      "query": {
        "search": {
          "lexical_fields": [
            "name",
            "description",
            "content",
            "path"
          ],
          "semantic_fields": [
            "description",
            "content"
          ]
        },
        "range_filters": {
          "mtime_epoch": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    },
    {
      "name": "skills",
      "description": "User-authored skills from ~/.codex/skills/<name>/SKILL.md. Frontmatter (name, description) is parsed; body is the skill content.",
      "display": {
        "label": "Your Codex skills",
        "detail": "Name, description, body, and source path for each skill."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "content": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "type": [
              "string",
              "null"
            ]
          },
          "mtime_epoch": {
            "type": [
              "integer",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "mtime_epoch",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": false,
      "query": {
        "search": {
          "lexical_fields": [
            "name",
            "description",
            "content",
            "path"
          ]
        },
        "range_filters": {
          "mtime_epoch": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    }
  ],
  "profiles": [
    {
      "id": "full",
      "label": "Your full Codex history",
      "streams": [
        {
          "name": "sessions"
        },
        {
          "name": "messages"
        },
        {
          "name": "function_calls"
        },
        {
          "name": "rules"
        },
        {
          "name": "prompts"
        },
        {
          "name": "skills"
        }
      ]
    },
    {
      "id": "messages_only",
      "label": "Just prompts and responses",
      "streams": [
        {
          "name": "sessions"
        },
        {
          "name": "messages"
        }
      ]
    },
    {
      "id": "authoring",
      "label": "Your prompts, skills, and approval rules",
      "streams": [
        {
          "name": "rules"
        },
        {
          "name": "prompts"
        },
        {
          "name": "skills"
        }
      ]
    }
  ]
}
