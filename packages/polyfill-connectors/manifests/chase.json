{
  "protocol_version": "0.1.0",
  "connector_id": "https://registry.pdpp.org/connectors/chase",
  "connector_key": "chase",
  "manifest_uri": "https://registry.pdpp.org/connectors/chase",
  "version": "0.1.0",
  "display_name": "Chase",
  "runtime_requirements": {
    "bindings": {
      "network": {
        "required": true
      },
      "browser": {
        "required": true
      }
    }
  },
  "setup": {
    "modality": "static_secret",
    "credential_capture": {
      "kind": "username_password",
      "label": "Chase sign-in details",
      "description": "Seal the Chase sign-in details for this source. The connector uses them only for this source's browser-backed collection.",
      "submit_label": "Save Chase credential and start first sync",
      "fields": [
        {
          "name": "username",
          "label": "Chase username",
          "type": "text",
          "required": true,
          "secret": true,
          "autocomplete": "username",
          "env": [
            "CHASE_USERNAME"
          ]
        },
        {
          "name": "password",
          "label": "Chase password",
          "type": "password",
          "required": true,
          "secret": true,
          "autocomplete": "current-password",
          "env": [
            "CHASE_PASSWORD"
          ]
        }
      ]
    }
  },
  "capabilities": {
    "human_interaction": [
      "otp",
      "manual_action"
    ],
    "refresh_policy": {
      "recommended_mode": "manual",
      "minimum_interval_seconds": 7200,
      "maximum_staleness_seconds": 86400,
      "interaction_posture": "otp_likely",
      "rate_limit_sensitivity": "medium",
      "bot_detection_sensitivity": "high",
      "background_safe": false,
      "rationale": "Chase requires OTP and short-lived browser sessions; never run a bank refresh in the background."
    },
    "public_listing": {
      "listed": true,
      "status": "needs_human_auth"
    }
  },
  "streams": [
    {
      "name": "accounts",
      "description": "Chase retail accounts (checking, savings, credit cards). Hybrid-sourced: identity + account type come from the QFX ACCTINFO response; friendly name, open date, and tier come from chase.com dashboard scrape.",
      "display": {
        "label": "Your Chase accounts",
        "detail": "Account names, types, last-four, current balance, and status. Credit card accounts additionally surface available credit and statement balance."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable connector-scoped identifier. Currently a hash of (account_type, account_number); will stabilize on Chase's internal account id once we scrape it from the dashboard DOM."
          },
          "name": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "primary-title"
          },
          "type": {
            "type": [
              "string",
              "null"
            ],
            "description": "checking | savings | credit_card | money_market | other"
          },
          "last_four": {
            "type": [
              "string",
              "null"
            ]
          },
          "balance_cents": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Ledger balance as of statement_as_of_date (QFX LEDGERBAL)."
          },
          "available_balance_cents": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Available balance if reported (QFX AVAILBAL)."
          },
          "credit_limit_cents": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Credit cards only. Null for checking/savings."
          },
          "available_credit_cents": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Credit cards only. Null for checking/savings."
          },
          "statement_balance_cents": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Credit cards only. Balance on most recent statement; null for checking/savings."
          },
          "status": {
            "type": [
              "string",
              "null"
            ]
          },
          "balance_as_of": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "x_pdpp_role": "event-time"
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": false,
      "query": {
        "search": {
          "lexical_fields": [
            "name",
            "type",
            "status"
          ]
        },
        "range_filters": {
          "balance_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "available_balance_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "available_credit_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "credit_limit_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "statement_balance_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "balance_as_of": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      },
      "coverage_strategy": "full_inventory",
      "freshness_strategy": "manual_as_of"
    },
    {
      "name": "transactions",
      "description": "Chase transactions per account, parsed from QFX (Quicken Web Connect) downloads. QFX is Chase's canonical transaction-export format: per-request date window is ~90 days, so the connector walks backward in 90-day chunks until QFX returns empty. Primary key is (account_id, fitid) — Chase's QFX FITID is a stable unique transaction identifier, so dedup across overlapping date windows collapses naturally. Amounts are in cents (integer, signed).",
      "display": {
        "label": "Your Chase transactions",
        "detail": "Date, signed amount in cents, cleaned payee name, original memo, Chase-assigned transaction type (DEBIT/CREDIT/CHECK/XFER/PAYMENT/FEE/etc.), check number, and FITID (Chase's stable transaction identifier). Pending transactions are not included — QFX delivers posted transactions only."
      },
      "semantics": "append_only",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "${account_id}|${fitid}. Chase's FITID is stable across re-exports."
          },
          "account_id": {
            "type": "string"
          },
          "account_name": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "actor"
          },
          "fitid": {
            "type": "string",
            "description": "Chase's internal Financial Institution Transaction ID. Verbatim from QFX STMTTRN."
          },
          "date": {
            "type": "string",
            "format": "date",
            "x_pdpp_type": "timestamp",
            "description": "Posted date. QFX DTPOSTED.",
            "x_pdpp_role": "event-time"
          },
          "amount": {
            "type": "integer",
            "x_pdpp_type": "currency",
            "description": "Signed amount in cents. Negative for debits, positive for credits."
          },
          "currency": {
            "type": "string",
            "description": "Always 'USD' for Chase retail accounts. QFX CURDEF."
          },
          "type": {
            "type": [
              "string",
              "null"
            ],
            "description": "QFX TRNTYPE: CREDIT | DEBIT | CHECK | XFER | PAYMENT | DEP | DIRECTDEP | DIRECTDEBIT | ATM | POS | FEE | SRVCHG | INT | DIV | CASH | OTHER."
          },
          "name": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_type": "text",
            "description": "Payee or merchant name. QFX NAME.",
            "x_pdpp_role": "primary-title"
          },
          "memo": {
            "type": [
              "string",
              "null"
            ],
            "description": "QFX MEMO. Often contains merchant city for CC transactions, or the raw bank descriptor for checking.",
            "x_pdpp_role": "secondary"
          },
          "check_number": {
            "type": [
              "string",
              "null"
            ],
            "description": "QFX CHECKNUM, when present."
          },
          "reference_number": {
            "type": [
              "string",
              "null"
            ],
            "description": "QFX REFNUM. Chase uses this for Zelle and wire transfers."
          },
          "source": {
            "type": "string",
            "description": "Always 'qfx_download_<YYYY-MM-DD>_to_<YYYY-MM-DD>'. Provenance for audit and re-extraction."
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "account_id",
          "fitid",
          "date",
          "amount",
          "currency"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "date",
      "consent_time_field": "date",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "account",
          "stream": "accounts",
          "foreign_key": "account_id",
          "cardinality": "has_one"
        }
      ],
      "views": [
        {
          "id": "reconciliation",
          "label": "Fields for matching to YNAB/Amazon",
          "fields": [
            "id",
            "account_id",
            "account_name",
            "date",
            "amount",
            "name",
            "memo",
            "check_number",
            "reference_number"
          ]
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "account_name",
            "name",
            "memo",
            "source",
            "reference_number"
          ],
          "semantic_fields": [
            "memo"
          ]
        },
        "range_filters": {
          "date": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "amount": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "sum": [
            "amount"
          ],
          "min": [
            "date",
            "amount"
          ],
          "max": [
            "date",
            "amount"
          ],
          "group_by": [
            "currency",
            "type"
          ],
          "group_by_time": [
            "date"
          ]
        }
      },
      "coverage_strategy": "parent_detail_accounting",
      "freshness_strategy": "manual_as_of"
    },
    {
      "name": "current_activity",
      "description": "Chase UI-visible account activity at scrape time. This mutable freshness stream can include pending rows and recently posted current-cycle rows from the signed-in Chase activity UI. It is not the settled QFX ledger; pending rows may change, disappear, or later post under a different QFX FITID.",
      "display": {
        "label": "Your current Chase activity",
        "detail": "Pending and current-cycle activity visible in Chase's account UI. Use this for freshness, not reconciliation. Posted ledger identity remains in the QFX-only transactions stream."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "${account_id}|${ui_transaction_id} when Chase exposes a UI id; otherwise ${account_id}|fallback:${hash(status|activity_date|posted_date|amount|description)}. Fallback keys do not promise pending-to-posted continuity."
          },
          "account_id": {
            "type": "string"
          },
          "account_name": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "actor"
          },
          "status": {
            "type": "string",
            "description": "pending | posted | unknown"
          },
          "activity_date": {
            "type": "string",
            "format": "date"
          },
          "posted_date": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "amount": {
            "type": "integer",
            "x_pdpp_type": "currency",
            "description": "Signed amount in cents. Negative for visible debits, positive for visible credits."
          },
          "currency": {
            "type": "string",
            "description": "Always 'USD' for Chase retail account UI rows in this connector."
          },
          "description": {
            "type": "string",
            "x_pdpp_role": "primary-title"
          },
          "memo": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "secondary"
          },
          "ui_transaction_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "Source-provided Chase UI transaction/activity id when present in DOM; null when the connector used the deterministic fallback key."
          },
          "source": {
            "type": "string",
            "description": "Always 'chase_activity_ui'."
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "x_pdpp_role": "event-time"
          }
        },
        "required": [
          "id",
          "account_id",
          "account_name",
          "status",
          "activity_date",
          "posted_date",
          "amount",
          "currency",
          "description",
          "memo",
          "ui_transaction_id",
          "source",
          "fetched_at"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "activity_date",
      "consent_time_field": "activity_date",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": false,
      "relationships": [
        {
          "name": "account",
          "stream": "accounts",
          "foreign_key": "account_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "account_name",
            "description",
            "memo",
            "status",
            "source"
          ],
          "semantic_fields": [
            "description",
            "memo"
          ]
        },
        "range_filters": {
          "activity_date": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "posted_date": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "amount": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "activity_date"
          ]
        }
      },
      "coverage_strategy": "checkpoint_window",
      "freshness_strategy": "manual_as_of"
    },
    {
      "name": "statements",
      "description": "Monthly statement PDFs per account from Chase's Statements & Documents page. Each record carries the document's title, delivery date, account reference, and — when the PDF is hydrated on-device — a content-addressed path + sha256. PDFs themselves live on the owner's disk under ~/.pdpp/chase-statements/<account>/<YYYY-MM>-<sha8>.pdf rather than in the RS, keeping blob storage out of SQLite per `design-notes/blob-hydration-open-question.md`.",
      "display": {
        "label": "Your Chase statements",
        "detail": "PDF monthly statements across all Chase accounts. Metadata is always captured (title, delivery date, account reference); PDF bytes are downloaded and stored locally with a content hash when blob hydration runs. The same hash reappears across runs so downloads are idempotent."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "SHA-256(account_reference|date_delivered|title), 32 hex chars."
          },
          "account_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "FK to accounts.id. Resolved by matching the statement row's account_reference back to the accounts stream. Null when neither last-four nor name substring match succeed."
          },
          "title": {
            "type": "string",
            "description": "Row title from the Statements & Documents table, e.g. `Sapphire Preferred (...9241)`.",
            "x_pdpp_role": "primary-title"
          },
          "date_delivered": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "account_reference": {
            "type": [
              "string",
              "null"
            ]
          },
          "document_url": {
            "type": [
              "string",
              "null"
            ],
            "description": "file:// URI for the stored PDF on disk. Populated only after blob hydration; null on index-only scrapes."
          },
          "pdf_path": {
            "type": [
              "string",
              "null"
            ],
            "description": "Absolute filesystem path of the downloaded PDF under ~/.pdpp/chase-statements/. Null until hydrated."
          },
          "pdf_sha256": {
            "type": [
              "string",
              "null"
            ],
            "description": "SHA-256 of the downloaded PDF bytes (raw blob content-address, not the content fingerprint — Chase re-encrypts the PDF per download, so it churns on no-op re-fetches)."
          },
          "pdf_text_sha256": {
            "type": [
              "string",
              "null"
            ],
            "description": "Positive content fingerprint: SHA-256 of the statement's extracted PDF text after deterministic normalization (NFC, whitespace collapse, trim). Stable across raw-byte churn so a re-download with unchanged content is provably a no-op. Null when text extraction failed or returned empty text."
          },
          "pdf_page_count": {
            "type": [
              "integer",
              "null"
            ],
            "description": "Integer page count from the PDF structure. A structural content invariant alongside pdf_text_sha256. Null when extraction failed."
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "x_pdpp_role": "event-time"
          }
        },
        "required": [
          "id",
          "title"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "date_delivered",
      "consent_time_field": "date_delivered",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "account",
          "stream": "accounts",
          "foreign_key": "account_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "title",
            "account_reference"
          ],
          "semantic_fields": [
            "title"
          ]
        },
        "range_filters": {
          "date_delivered": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "date_delivered"
          ]
        }
      },
      "coverage_strategy": "parent_detail_accounting",
      "freshness_strategy": "manual_as_of"
    },
    {
      "name": "balances",
      "description": "Point-in-time balance snapshots per account. One record per QFX response per account. Useful for reconstructing historical balances between statement dates.",
      "display": {
        "label": "Your Chase balance snapshots",
        "detail": "Ledger and available balance per account, timestamped to the QFX response's balance-as-of date. Each run produces one snapshot per account; snapshots accumulate rather than replace, preserving the history."
      },
      "semantics": "append_only",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "${account_id}|${as_of_iso}"
          },
          "account_id": {
            "type": "string"
          },
          "as_of": {
            "type": "string",
            "format": "date-time",
            "description": "QFX DTASOF — when Chase measured the balance."
          },
          "ledger_balance_cents": {
            "type": [
              "integer",
              "null"
            ],
            "description": "QFX LEDGERBAL."
          },
          "available_balance_cents": {
            "type": [
              "integer",
              "null"
            ],
            "description": "QFX AVAILBAL."
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time",
            "x_pdpp_role": "event-time"
          }
        },
        "required": [
          "id",
          "account_id",
          "as_of"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "as_of",
      "consent_time_field": "as_of",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "account",
          "stream": "accounts",
          "foreign_key": "account_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "range_filters": {
          "as_of": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "ledger_balance_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "available_balance_cents": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "as_of"
          ]
        }
      },
      "coverage_strategy": "singleton_presence",
      "freshness_strategy": "manual_as_of"
    }
  ]
}
