{
  "protocol_version": "0.1.0",
  "connector_id": "https://registry.pdpp.org/connectors/claude-code",
  "version": "0.2.0",
  "display_name": "Claude Code",
  "runtime_requirements": {
    "bindings": {
      "filesystem": {
        "required": true
      }
    }
  },
  "capabilities": {
    "human_interaction": []
  },
  "streams": [
    {
      "name": "sessions",
      "description": "Claude Code sessions. One session = one CLI invocation in a specific project directory.",
      "display": {
        "label": "Your Claude Code sessions",
        "detail": "Session start time, duration, project directory, git branch, Claude Code version, total message count."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "project_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "cwd": {
            "type": [
              "string",
              "null"
            ]
          },
          "git_branch": {
            "type": [
              "string",
              "null"
            ]
          },
          "version": {
            "type": [
              "string",
              "null"
            ]
          },
          "started_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "last_event_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "message_count": {
            "type": [
              "integer",
              "null"
            ]
          },
          "user_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "entrypoint": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "last_event_at",
      "consent_time_field": "started_at",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "query": {
        "search": {
          "lexical_fields": [
            "project_path",
            "cwd",
            "git_branch",
            "version",
            "user_type",
            "entrypoint"
          ]
        },
        "range_filters": {
          "started_at": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "last_event_at": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "message_count": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    },
    {
      "name": "messages",
      "description": "Messages within Claude Code sessions: user prompts and assistant responses. Includes both top-level session transcripts and nested subagent (sidechain) transcripts.",
      "display": {
        "label": "Your Claude Code messages",
        "detail": "Role (user/assistant), text content, timestamp, parent message (for threading), session reference, subagent id when the message came from a sidechain run."
      },
      "semantics": "append_only",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "parent_uuid": {
            "type": [
              "string",
              "null"
            ]
          },
          "role": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          },
          "content": {
            "type": [
              "string",
              "null"
            ]
          },
          "timestamp": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "is_sidechain": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "user_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "agent_id": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "session_id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "timestamp",
      "consent_time_field": "timestamp",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "session",
          "stream": "sessions",
          "foreign_key": "session_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "role",
            "type",
            "content",
            "user_type",
            "agent_id"
          ],
          "semantic_fields": [
            "content"
          ]
        },
        "range_filters": {
          "timestamp": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    },
    {
      "name": "attachments",
      "description": "Non-message events: hook outputs, tool uses, file snapshots, plus tool-results blob files written to disk.",
      "display": {
        "label": "Claude Code events",
        "detail": "System events attached to sessions: tool calls, hook outputs, file-history snapshots, permission-mode changes, and persisted tool-result files."
      },
      "semantics": "append_only",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "parent_uuid": {
            "type": [
              "string",
              "null"
            ]
          },
          "event_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "hook_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "tool_use_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "content_preview": {
            "type": [
              "string",
              "null"
            ]
          },
          "content_bytes": {
            "type": [
              "integer",
              "null"
            ]
          },
          "timestamp": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "session_id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "timestamp",
      "consent_time_field": "timestamp",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "session",
          "stream": "sessions",
          "foreign_key": "session_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "event_type",
            "hook_name",
            "content_preview"
          ],
          "semantic_fields": [
            "content_preview"
          ]
        },
        "range_filters": {
          "timestamp": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "content_bytes": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    },
    {
      "name": "skills",
      "description": "User-authored Claude Code skills installed under ~/.claude/skills/<skill>/SKILL.md. Each record captures frontmatter metadata and the full body (capped at 20k chars).",
      "display": {
        "label": "Your Claude Code skills",
        "detail": "Skill name, description, full SKILL.md body, frontmatter, and on-disk path."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "source": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "type": [
              "string",
              "null"
            ]
          },
          "content": {
            "type": [
              "string",
              "null"
            ]
          },
          "frontmatter": {
            "type": [
              "object",
              "null"
            ]
          },
          "mtime_epoch": {
            "type": [
              "integer",
              "null"
            ]
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "mtime_epoch",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": false,
      "query": {
        "search": {
          "lexical_fields": [
            "name",
            "description",
            "source",
            "content"
          ],
          "semantic_fields": [
            "description",
            "content"
          ]
        },
        "range_filters": {
          "mtime_epoch": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    },
    {
      "name": "slash_commands",
      "description": "User-authored Claude Code slash commands under ~/.claude/commands/*.md. Each record captures frontmatter, the command body (capped at 20k chars), and the file's absolute path.",
      "display": {
        "label": "Your custom slash commands",
        "detail": "Command name, description, full command body, frontmatter, and on-disk path."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "type": [
              "string",
              "null"
            ]
          },
          "content": {
            "type": [
              "string",
              "null"
            ]
          },
          "frontmatter": {
            "type": [
              "object",
              "null"
            ]
          },
          "mtime_epoch": {
            "type": [
              "integer",
              "null"
            ]
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "mtime_epoch",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": false,
      "query": {
        "search": {
          "lexical_fields": [
            "name",
            "description",
            "content"
          ],
          "semantic_fields": [
            "description",
            "content"
          ]
        },
        "range_filters": {
          "mtime_epoch": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    }
  ],
  "profiles": [
    {
      "id": "full",
      "label": "Your full Claude Code history",
      "streams": [
        {
          "name": "sessions"
        },
        {
          "name": "messages"
        },
        {
          "name": "attachments"
        },
        {
          "name": "skills"
        },
        {
          "name": "slash_commands"
        }
      ]
    },
    {
      "id": "messages_only",
      "label": "Just prompts and responses",
      "streams": [
        {
          "name": "sessions"
        },
        {
          "name": "messages"
        }
      ]
    },
    {
      "id": "customizations",
      "label": "Your skills and slash commands",
      "streams": [
        {
          "name": "skills"
        },
        {
          "name": "slash_commands"
        }
      ]
    }
  ]
}
