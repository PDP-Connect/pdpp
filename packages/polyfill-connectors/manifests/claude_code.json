{
  "protocol_version": "0.1.0",
  "connector_id": "https://registry.pdpp.org/connectors/claude-code",
  "connector_key": "claude-code",
  "manifest_uri": "https://registry.pdpp.org/connectors/claude-code",
  "version": "0.3.0",
  "display_name": "Claude Code",
  "runtime_requirements": {
    "bindings": {
      "filesystem": {
        "required": true
      }
    }
  },
  "capabilities": {
    "human_interaction": [],
    "refresh_policy": {
      "recommended_mode": "automatic",
      "recommended_interval_seconds": 3600,
      "minimum_interval_seconds": 300,
      "maximum_staleness_seconds": 21600,
      "interaction_posture": "none",
      "rate_limit_sensitivity": "low",
      "bot_detection_sensitivity": "low",
      "background_safe": true,
      "rationale": "Claude Code session logs live on local disk; re-reading them is cheap and has no platform cost."
    },
    "public_listing": {
      "listed": true,
      "status": "proven"
    }
  },
  "streams": [
    {
      "name": "sessions",
      "description": "Claude Code sessions. One session = one CLI invocation in a specific project directory.",
      "display": {
        "label": "Your Claude Code sessions",
        "detail": "Session start time, duration, project directory, git branch, Claude Code version, total message count."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "project_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "cwd": {
            "type": [
              "string",
              "null"
            ]
          },
          "git_branch": {
            "type": [
              "string",
              "null"
            ]
          },
          "version": {
            "type": [
              "string",
              "null"
            ]
          },
          "started_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "x_pdpp_role": "event-time"
          },
          "last_event_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "message_count": {
            "type": [
              "integer",
              "null"
            ]
          },
          "user_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "entrypoint": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "last_event_at",
      "consent_time_field": "started_at",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "query": {
        "search": {
          "lexical_fields": [
            "project_path",
            "cwd",
            "git_branch",
            "version",
            "user_type",
            "entrypoint"
          ]
        },
        "range_filters": {
          "started_at": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "last_event_at": [
            "gte",
            "gt",
            "lte",
            "lt"
          ],
          "message_count": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "last_event_at"
          ]
        }
      }
    },
    {
      "name": "messages",
      "description": "Messages within Claude Code sessions: user prompts and assistant responses. Includes both top-level session transcripts and nested subagent (sidechain) transcripts.",
      "display": {
        "label": "Your Claude Code messages",
        "detail": "Role (user/assistant), text content, timestamp, parent message (for threading), session reference, subagent id when the message came from a sidechain run."
      },
      "semantics": "append_only",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "parent_uuid": {
            "type": [
              "string",
              "null"
            ]
          },
          "role": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "actor"
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          },
          "content": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "primary-title"
          },
          "timestamp": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "x_pdpp_role": "event-time"
          },
          "is_sidechain": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "user_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "agent_id": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "session_id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "timestamp",
      "consent_time_field": "timestamp",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "relationships": [
        {
          "name": "session",
          "stream": "sessions",
          "foreign_key": "session_id",
          "cardinality": "has_one"
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "role",
            "type",
            "content",
            "user_type",
            "agent_id"
          ],
          "semantic_fields": [
            "content"
          ]
        },
        "range_filters": {
          "timestamp": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "timestamp"
          ]
        }
      }
    },
    {
      "name": "attachments",
      "description": "Non-message events: hook outputs, tool uses, file snapshots, plus tool-results blob files written to disk.",
      "display": {
        "label": "Claude Code events",
        "detail": "System events attached to sessions: tool calls, hook outputs, file-history snapshots, permission-mode changes, and persisted tool-result files."
