{
  "protocol_version": "0.1.0",
  "connector_id": "https://registry.pdpp.org/connectors/strava",
  "connector_key": "strava",
  "manifest_uri": "https://registry.pdpp.org/connectors/strava",
  "version": "0.1.0",
  "display_name": "Strava",
  "runtime_requirements": {
    "bindings": {
      "network": {
        "required": true
      }
    }
  },
  "capabilities": {
    "human_interaction": [],
    "refresh_policy": {
      "recommended_mode": "automatic",
      "recommended_interval_seconds": 21600,
      "minimum_interval_seconds": 3600,
      "maximum_staleness_seconds": 86400,
      "interaction_posture": "none",
      "rate_limit_sensitivity": "medium",
      "bot_detection_sensitivity": "low",
      "background_safe": true,
      "rationale": "Strava activities are uploaded after workouts; six-hourly refresh stays well inside rate limits."
    },
    "public_listing": {
      "listed": true,
      "status": "proven"
    },
    "auth": {
      "kind": "env",
      "required": [
        "STRAVA_ACCESS_TOKEN"
      ]
    }
  },
  "streams": [
    {
      "name": "activities",
      "description": "Strava activities (runs, rides, swims, etc.).",
      "display": {
        "label": "Your Strava activities",
        "detail": "Activity name, type, start time, distance, moving time, elapsed time, elevation, average speed, kudos/comment counts, achievement counts."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": [
              "string",
              "null"
            ],
            "x_pdpp_role": "primary-title"
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          },
          "sport_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "start_date": {
            "type": "string",
            "format": "date-time",
            "x_pdpp_role": "event-time"
          },
          "start_date_local": {
            "type": [
              "string",
              "null"
            ]
          },
          "timezone": {
            "type": [
              "string",
              "null"
            ]
          },
          "distance_m": {
            "type": [
              "number",
              "null"
            ]
          },
          "moving_time_s": {
            "type": [
              "integer",
              "null"
            ]
          },
          "elapsed_time_s": {
            "type": [
              "integer",
              "null"
            ]
          },
          "total_elevation_gain_m": {
            "type": [
              "number",
              "null"
            ]
          },
          "average_speed_mps": {
            "type": [
              "number",
              "null"
            ]
          },
          "max_speed_mps": {
            "type": [
              "number",
              "null"
            ]
          },
          "average_heartrate": {
            "type": [
              "number",
              "null"
            ]
          },
          "max_heartrate": {
            "type": [
              "number",
              "null"
            ]
          },
          "kudos_count": {
            "type": [
              "integer",
              "null"
            ]
          },
          "comment_count": {
            "type": [
              "integer",
              "null"
            ]
          },
          "achievement_count": {
            "type": [
              "integer",
              "null"
            ]
          },
          "start_latlng": {
            "type": "array"
          },
          "end_latlng": {
            "type": "array"
          },
          "map_polyline": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "start_date"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "start_date",
      "consent_time_field": "start_date",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "query": {
        "search": {
          "lexical_fields": [
            "name"
          ]
        },
        "range_filters": {
          "start_date": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "start_date"
          ],
          "group_by": [
            "type",
            "sport_type"
          ]
        }
      },
      "coverage_strategy": "checkpoint_window",
      "freshness_strategy": "scheduled_window"
    }
  ]
}
