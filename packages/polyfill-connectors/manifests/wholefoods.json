{
  "protocol_version": "0.1.0",
  "connector_id": "https://registry.pdpp.org/connectors/wholefoods",
  "connector_key": "wholefoods",
  "manifest_uri": "https://registry.pdpp.org/connectors/wholefoods",
  "version": "0.1.0",
  "display_name": "Whole Foods",
  "runtime_requirements": {
    "bindings": {
      "network": {
        "required": true
      },
      "browser": {
        "required": true
      }
    }
  },
  "capabilities": {
    "human_interaction": [
      "manual_action",
      "otp"
    ],
    "refresh_policy": {
      "recommended_mode": "manual",
      "minimum_interval_seconds": 7200,
      "interaction_posture": "otp_likely",
      "rate_limit_sensitivity": "medium",
      "bot_detection_sensitivity": "high",
      "background_safe": false,
      "rationale": "Whole Foods (via Amazon) frequently requires OTP and triggers bot-detection; refresh manually."
    },
    "public_listing": {
      "listed": false,
      "status": "unproven"
    }
  },
  "streams": [
    {
      "name": "orders",
      "description": "Whole Foods orders via Amazon.",
      "display": {
        "label": "Your Whole Foods orders",
        "detail": "Order date, store, total, delivery status. Uses your Amazon login."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "order_date": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "x_pdpp_role": "event-time"
          },
          "store": {
            "type": [
              "string",
              "null"
            ]
          },
          "method": {
            "type": [
              "string",
              "null"
            ]
          },
          "total_cents": {
            "type": [
              "integer",
              "null"
            ]
          },
          "item_count": {
            "type": [
              "integer",
              "null"
            ]
          }
        },
        "required": [
          "id"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "order_date",
      "consent_time_field": "order_date",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "query": {
        "search": {
          "lexical_fields": [
            "store"
          ]
        },
        "range_filters": {
          "order_date": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        },
        "aggregations": {
          "count": true,
          "group_by_time": [
            "order_date"
          ],
          "group_by": [
            "method"
          ]
        }
      }
    },
    {
      "name": "order_items",
      "description": "Items within Whole Foods orders, with nutrition when available.",
      "display": {
        "label": "Your Whole Foods items",
        "detail": "Product name, quantity, price, nutrition info (USDA/API-sourced)."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "order_id": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "x_pdpp_role": "primary-title"
          },
          "quantity": {
            "type": [
              "number",
              "null"
            ]
          },
          "unit_price_cents": {
            "type": [
              "integer",
              "null"
            ]
          },
          "nutrition": {
            "type": [
              "object",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "order_id",
          "name"
        ]
      },
      "primary_key": [
        "id"
      ],
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": true,
      "query": {
        "search": {
          "lexical_fields": [
            "name"
          ]
        }
      }
    }
  ]
}
