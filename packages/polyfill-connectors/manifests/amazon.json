{
  "protocol_version": "0.1.0",
  "connector_id": "https://registry.pdpp.org/connectors/amazon",
  "version": "0.1.0",
  "display_name": "Amazon",
  "runtime_requirements": {
    "bindings": {
      "network": { "required": true }
    }
  },
  "capabilities": {
    "human_interaction": ["manual_action", "otp"]
  },
  "streams": [
    {
      "name": "orders",
      "description": "Amazon retail orders scraped from Your Orders.",
      "display": {
        "label": "Your Amazon orders",
        "detail": "Order IDs, dates, totals, delivery status, shipping summaries, payment method summary, recipient name. Per-item breakdowns live in the order_items stream."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "order_date": { "type": "string", "format": "date" },
          "order_total": { "type": ["string", "null"] },
          "order_total_cents": { "type": ["integer", "null"] },
          "delivery_status": { "type": ["string", "null"] },
          "status_detail": { "type": ["string", "null"] },
          "recipient_name": { "type": ["string", "null"] },
          "shipping_address_summary": { "type": ["string", "null"] },
          "payment_method_summary": { "type": ["string", "null"] },
          "gift_order": { "type": "boolean" },
          "digital_order": { "type": "boolean" },
          "item_count": { "type": "integer" },
          "fetched_at": { "type": "string" }
        },
        "required": ["id", "order_date"]
      },
      "primary_key": ["id"],
      "cursor_field": "order_date",
      "consent_time_field": "order_date",
      "selection": { "fields": true, "resources": true },
      "incremental": true,
      "views": [
        { "id": "reconciliation", "label": "Fields for matching to bank/YNAB transactions", "fields": ["id", "order_date", "order_total", "order_total_cents", "payment_method_summary", "delivery_status", "item_count"] },
        { "id": "full", "label": "Everything on the order row", "fields": ["id", "order_date", "order_total", "order_total_cents", "delivery_status", "status_detail", "recipient_name", "shipping_address_summary", "payment_method_summary", "gift_order", "digital_order", "item_count", "fetched_at"] }
      ]
    },
    {
      "name": "order_items",
      "description": "Line items within Amazon orders.",
      "display": {
        "label": "Your order line items",
        "detail": "Product titles, ASINs, per-unit prices, quantities, sellers, product URLs, item-level return/refund status."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "order_id": { "type": "string" },
          "order_date": { "type": "string", "format": "date" },
          "asin": { "type": ["string", "null"] },
          "name": { "type": "string" },
          "url": { "type": ["string", "null"] },
          "unit_price": { "type": ["string", "null"] },
          "unit_price_cents": { "type": ["integer", "null"] },
          "quantity": { "type": "integer" },
          "seller": { "type": ["string", "null"] },
          "item_image_url": { "type": ["string", "null"] },
          "returned": { "type": "boolean" },
          "refund_status": { "type": ["string", "null"] }
        },
        "required": ["id", "order_id", "order_date", "name"]
      },
      "primary_key": ["id"],
      "cursor_field": "order_date",
      "consent_time_field": "order_date",
      "selection": { "fields": true, "resources": true },
      "incremental": true,
      "relationships": [
        { "name": "order", "stream": "orders", "foreign_key": "order_id", "cardinality": "has_one" }
      ]
    }
  ],
  "profiles": [
    {
      "id": "reconciliation",
      "label": "Orders for bank/YNAB matching",
      "streams": [
        { "name": "orders", "view": "reconciliation" },
        { "name": "order_items" }
      ]
    }
  ]
}
