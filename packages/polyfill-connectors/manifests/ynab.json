    {
      "name": "budgets",
      "description": "YNAB budgets (plans) the user owns or collaborates on. Includes currency/date locale.",
      "display": {
        "label": "Your budgets",
        "detail": "Budget names, currency locale (ISO code, symbol, separators), date format, and first/last month. No transaction data."
      },
      "semantics": "mutable_state",
      "schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "last_modified_on": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "first_month": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_month": {
            "type": [
              "string",
              "null"
            ]
          },
          "currency_iso_code": {
            "type": [
              "string",
              "null"
            ]
          },
          "currency_symbol": {
            "type": [
              "string",
              "null"
            ]
          },
          "currency_symbol_first": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "currency_decimal_digits": {
            "type": [
              "integer",
              "null"
            ]
          },
          "currency_decimal_separator": {
            "type": [
              "string",
              "null"
            ]
          },
          "currency_group_separator": {
            "type": [
              "string",
              "null"
            ]
          },
          "date_format_string": {
            "type": [
              "string",
              "null"
            ]
          },
          "deleted": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "primary_key": [
        "id"
      ],
      "cursor_field": "last_modified_on",
      "selection": {
        "fields": true,
        "resources": true
      },
      "incremental": false,
      "views": [
        {
          "id": "basic",
          "label": "Budget names and metadata",
          "fields": [
            "id",
            "name",
            "currency_iso_code"
          ]
        },
        {
          "id": "full",
          "label": "All budget fields",
          "fields": [
            "id",
            "name",
            "last_modified_on",
            "first_month",
            "last_month",
            "currency_iso_code",
            "currency_symbol",
            "currency_symbol_first",
            "currency_decimal_digits",
            "currency_decimal_separator",
            "currency_group_separator",
            "date_format_string",
            "deleted"
          ]
        }
      ],
      "query": {
        "search": {
          "lexical_fields": [
            "name",
            "currency_iso_code",
            "currency_symbol",
            "date_format_string"
          ]
        },
        "range_filters": {
          "last_modified_on": [
            "gte",
            "gt",
            "lte",
            "lt"
          ]
        }
      }
    },
