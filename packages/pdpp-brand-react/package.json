{
  "name": "@pdpp/brand-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ink Carbon React component library — the framework-bound layer atop @pdpp/brand tokens. Ships .tsx sources directly (no build step); transpiled by the consuming app's Next bundler via transpilePackages. Component styling (components.css / shell.css) ships alongside the components.",
  "exports": {
    ".": "./src/index.ts",
    "./components.css": "./src/components.css",
    "./shell.css": "./src/shell.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "node --test --import tsx --import ./css-stub-register.mjs 'src/**/*.test.ts'",
    "verify": "pnpm typecheck && pnpm check && pnpm test"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "@pdpp/brand": "workspace:*"
  },
  "peerDependencies": {
    "next": "^16.2.2",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "ultracite": "7.9.4"
  },
  "license": "Apache-2.0"
}
