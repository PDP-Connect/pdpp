{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "root": true,
  "extends": ["ultracite/biome/core", "ultracite/biome/type-aware"],
  "formatter": {
    "lineWidth": 120
  },
  "files": {
    "ignoreUnknown": true,
    // During the JS→TS migration, Biome only lints/formats .ts files plus
    // config. Legacy .js files are exempt until migrated — renaming to .ts
    // automatically brings them under the strict bar. Flip this to include
    // *.js once the migration is complete and delete the note.
    "includes": [
      "src/**/*.ts",
      "connectors/**/*.ts",
      "bin/**/*.ts",
      "packages/remote-surface/src/**/*.ts",
      "packages/remote-surface/*.json",
      "*.jsonc",
      "*.json",
      "!node_modules",
      "!fixtures",
      "!dist",
      "!**/*.test.*",
      // Ultracite 7.9.4 adds a broad `**` include in its preset. These force
      // ignores preserve this repository's existing TypeScript-only migration
      // boundary even after configs merge.
      "!!**/*.js",
      "!!**/*.jsx",
      "!!**/*.mjs",
      "!!**/*.cjs",
      "!!**/*.css",
      "!!**/*.html"
    ]
  },
  "overrides": [
    {
      // This is an authored design exploration archive (HTML/CSS/JS prototypes),
      // not product source. It has no TypeScript project or runtime test surface;
      // linting it under the repository's strict application rules produces
      // undeclared-global false positives rather than actionable code findings.
      // The rest of docs/design-system is the same exploratory material.
      "includes": ["docs/design-system/**"],
      "assist": {
        "enabled": false
      },
      "formatter": {
        "enabled": false
      },
      "linter": {
        "enabled": false
      }
    },
    {
      // Remote-surface was previously outside the workspace check set, so
      // `pnpm --filter @opendatalabs/remote-surface check` was a false green. Keep
      // the package under Biome analysis now, but waive the pre-existing
      // Ultracite migration debt that surfaced when the files became visible.
      //
      // This is intentionally scoped to packages/remote-surface/src/**/*.ts:
      // new syntax/configuration problems and any non-waived Ultracite rules
      // still fail the package check, while style/assist cleanup can land in a
      // separate product-code-only tranche.
      "includes": ["packages/remote-surface/src/**/*.ts"],
      "formatter": {
        "enabled": false
      },
      "assist": {
        "actions": {
          "source": {
            "organizeImports": "off",
            "useSortedInterfaceMembers": "off"
          }
        }
      },
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noUselessUndefined": "off",
            "noVoid": "off",
            "useSimplifiedLogicExpression": "off"
          },
          "correctness": {
            "noUnresolvedImports": "off"
          },
          "performance": {
            "noBarrelFile": "off"
          },
          "style": {
            "useBlockStatements": "off",
            "useConsistentTypeDefinitions": "off",
            "useExportType": "off",
            "useNumericSeparators": "off"
          },
          "suspicious": {
            "useAwait": "off"
          }
        }
      }
    },
    {
      // Connector-specific override. As of 2026-04-22 only
      // noExcessiveCognitiveComplexity is relaxed here — all other migration
      // escape valves (useTopLevelRegex, noNestedTernary, noAssignInExpressions,
      // noBitwiseOperators, noImplicitAnyLet, noEvolvingTypes, useTemplate)
      // have been eliminated and their violations fixed in-place.
      //
      // 30 connector functions exceed the default cognitive-complexity budget
      // of 20 (range 21–255). They fall into three buckets that cannot be
      // cleanly decomposed:
      //   (a) page.evaluate(() => {...}) callbacks (chase enumerate,
      //       chatgpt auth, usaa diagnostics, etc.). The callback body is
      //       serialized and shipped to the browser — helpers defined in
      //       Node cannot cross the bridge, so decomposition forces either
      //       duplicated inline helpers or contorted parameter threading.
      //   (b) collect() orchestrators that own cursor lifetime, emit
      //       ordering, dedup keys, and multi-stream coordination
      //       (chatgpt c=199, gmail c=220, slack c=255, usaa c=236).
      //       Breaking these fragments invariants that must hold together
      //       ("emit RECORD before advance cursor", "normalize → shape-check
      //       → emit → state-advance per item").
      //   (c) Tree/DOM walkers and loosely-typed parsers (chase QFX-tree
      //       extraction, codex walkRollouts generator, ical VEVENT line
      //       parser). Their branching mirrors the external format.
      // Re-enable per file after the connector moves to the
      // makeEmitRecord + named stream-helper pattern (see
      // src/connector-runtime.ts).
      "includes": ["connectors/**/*.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    }
  ]
}
