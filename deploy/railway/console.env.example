# PDPP Railway console service env template
#
# Copy into the public `console` service's Railway Variables tab and replace
# placeholders. Do not set PORT; Railway injects the public service port.

PDPP_REFERENCE_ORIGIN=https://<your-console-domain>
PDPP_REFERENCE_MODE=composed
PDPP_OWNER_PASSWORD=
PDPP_OWNER_SUBJECT_ID=owner_local
PDPP_TRUSTED_HOSTS=

PDPP_AS_URL=http://reference.railway.internal:7662
PDPP_RS_URL=http://reference.railway.internal:7663
PDPP_ENABLE_DASHBOARD=1
