# PDPP Railway reference service env template
#
# Copy into the private `reference` service's Railway Variables tab and replace
# placeholders. Do not set PORT; Railway injects it and the reference image
# maps it to the private AS listener at startup.

PDPP_REFERENCE_ORIGIN=https://${{console.RAILWAY_PUBLIC_DOMAIN}}
PDPP_OWNER_PASSWORD=
PDPP_CREDENTIAL_ENCRYPTION_KEY=${{ secret(64) }}
PDPP_TRUSTED_HOSTS=

# Optional Google Data Portability OAuth app for the API-backed Google Maps
# Data Portability source. These are deployment-level OAuth app settings, not
# per-account Google credentials and not Gmail app passwords.
# GOOGLE_DATAPORTABILITY_CLIENT_ID=
# GOOGLE_DATAPORTABILITY_CLIENT_SECRET=
# GOOGLE_DATAPORTABILITY_REDIRECT_URI=https://${{console.RAILWAY_PUBLIC_DOMAIN}}/_ref/provider-auth/callback
# GOOGLE_DATAPORTABILITY_RESOURCE_GROUPS=

# Option A (recommended): managed Postgres.
PDPP_DATABASE_URL=${{Postgres.DATABASE_URL}}

# Option B: SQLite on a mounted persistent volume.
# Uncomment these and leave PDPP_STORAGE_BACKEND / PDPP_DATABASE_URL above unset.
# PDPP_STORAGE_BACKEND=sqlite
# PDPP_DB_PATH=/data/pdpp.sqlite
