# PDPP Railway reference service env template
#
# Copy into the private `reference` service's Railway Variables tab and replace
# placeholders. PORT is intentionally set to the AS listener so Railway's
# healthcheck targets `/.well-known/oauth-authorization-server`.

PDPP_REFERENCE_ORIGIN=https://<your-console-domain>
PDPP_REFERENCE_MODE=composed
PDPP_OWNER_PASSWORD=
PDPP_OWNER_SUBJECT_ID=owner_local
PDPP_TRUSTED_HOSTS=

NODE_ENV=production
PORT=7662
AS_PORT=7662
RS_PORT=7663
PDPP_REFERENCE_OPERATIONAL_DEFAULTS=1
PDPP_RS_URL=http://127.0.0.1:7663
PDPP_EMBEDDING_DOWNLOAD_ALLOWED=0

# Option A (recommended): managed Postgres.
PDPP_STORAGE_BACKEND=postgres
PDPP_DATABASE_URL=${{Postgres.DATABASE_URL}}

# Option B: SQLite on a mounted persistent volume.
# Uncomment these and leave PDPP_STORAGE_BACKEND / PDPP_DATABASE_URL above unset.
# PDPP_STORAGE_BACKEND=sqlite
# PDPP_DB_PATH=/data/pdpp.sqlite
