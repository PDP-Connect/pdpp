# PDPP Fly.io Core app
#
# Selected path: one public Fly app runs the console on internal port 3000 and
# runs the reference AS/RS privately on loopback inside the same machine. Do not
# set PORT, AS_PORT, RS_PORT, PDPP_AS_URL, or PDPP_RS_URL as Fly app variables;
# the platform-core image owns them.
#
# Preflight (the committed placeholders intentionally fail until filled):
#   node scripts/check-flyio-deploy-env.mjs --core deploy/flyio/core.env.example

PDPP_REFERENCE_ORIGIN=https://<app-name>.fly.dev
PDPP_OWNER_PASSWORD=<required-non-empty-secret>

# `fly launch --db` attaches DATABASE_URL automatically. PDPP_DATABASE_URL is
# also accepted and takes precedence over DATABASE_URL when both are set.
DATABASE_URL=<postgres-connection-string>
