# PDPP — Fly.io Core deploy target: console app environment
#
# Set these as Fly secrets (never commit secrets to fly.toml or source):
#   fly secrets set --app <console-app-name> KEY=value
#
# This is the public console app. It proxies the full protocol surface to the
# private reference app over Fly's internal WireGuard network.

# ---------------------------------------------------------------------------
# Public origin — the console app's public HTTPS URL.
# Composed mode advertises this as the AS issuer and RS resource.
# Replace with your custom domain if you configure one.
# ---------------------------------------------------------------------------
PDPP_REFERENCE_ORIGIN=https://<console-app-name>.fly.dev

# ---------------------------------------------------------------------------
# Private reference app targets — reachable only over the Fly internal network.
# Replace <reference-app-name> with the name of your reference Fly app.
# These MUST use *.internal hostnames, not public URLs or localhost.
# ---------------------------------------------------------------------------
PDPP_AS_URL=http://<reference-app-name>.internal:7662
PDPP_RS_URL=http://<reference-app-name>.internal:7663

# ---------------------------------------------------------------------------
# Owner gate — REQUIRED. A non-empty high-entropy value.
# Generate: openssl rand -base64 24
# The owner-session signing key derives from this value; keep it stable across
# restarts. There is no separate session secret to set.
# ---------------------------------------------------------------------------
PDPP_OWNER_PASSWORD=

# ---------------------------------------------------------------------------
# Storage — Postgres connection string from fly postgres attach.
# fly postgres attach writes DATABASE_URL into the app; map it here.
# ---------------------------------------------------------------------------
PDPP_DATABASE_URL=

# NODE_ENV is set in fly.toml [env] block; do not set it here as a secret.
