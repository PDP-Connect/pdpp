# PDPP — Fly.io Core deploy target: reference app environment
#
# Set these as Fly secrets on the reference app:
#   fly secrets set --app <reference-app-name> KEY=value
#
# This is the private reference app (AS + RS). It has no public service block;
# it is reachable only at <reference-app-name>.internal over Fly's WireGuard
# private network.

# ---------------------------------------------------------------------------
# Public origin — same value as the console app's PDPP_REFERENCE_ORIGIN.
# Composed mode uses this to advertise the AS issuer and RS resource correctly.
# ---------------------------------------------------------------------------
PDPP_REFERENCE_ORIGIN=https://<console-app-name>.fly.dev

# ---------------------------------------------------------------------------
# Owner gate — same value as the console app's PDPP_OWNER_PASSWORD.
# Required: the reference app also checks the owner password for owner-gated routes.
# ---------------------------------------------------------------------------
PDPP_OWNER_PASSWORD=

# ---------------------------------------------------------------------------
# Storage — same Postgres connection string as the console app.
# ---------------------------------------------------------------------------
PDPP_DATABASE_URL=

# NODE_ENV, PORT, AS_PORT, RS_PORT, PDPP_RS_URL, PDPP_EMBEDDING_DOWNLOAD_ALLOWED,
# and PDPP_REFERENCE_OPERATIONAL_DEFAULTS are set in fly.reference.toml [env];
# do not duplicate them here as secrets.
